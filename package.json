{
  "name": "aruma",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "build": "astro build && node scripts/copy-katex-css.js && node scripts/extract-math-symbols.js && node scripts/compress-katex-fonts.js && pagefind --site dist && node scripts/compress-fonts.js",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "tsc --noEmit --isolatedDeclarations",
    "format": "prettier --write ./src",
    "lint": "prettier --check ./src"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.7",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/node": "^10.0.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^6.0.2",
    "clsx": "^2.1.1",
    "hastscript": "^9.0.1",
    "katex": "^0.16.38",
    "lucide-astro": "^0.556.0",
    "mdui": "^2.1.4",
    "pace-js": "^1.2.4",
    "pagefind": "^1.4.0",
    "photoswipe": "^5.4.4",
    "qrcode": "^1.5.4",
    "rehype-components": "^0.3.0",
    "rehype-katex": "^7.0.1",
    "remark-directive": "^3.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "fontmin": "^1.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1"
  },
  "pnpm": {
    "overrides": {
      "ttf2woff2": "4.0.5"
    },
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "ttf2woff2"
    ]
  }
}