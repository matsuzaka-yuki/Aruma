---
export interface Props {
	cardSelector: string;
	listContainerId: string;
	paginationId?: string;
	hiddenClass?: string;
	pageSize?: number;
}

const {
	cardSelector,
	listContainerId,
	paginationId,
	hiddenClass = "flip-hidden",
	pageSize = 0,
} = Astro.props;

const paginationPrevId = paginationId ? `${paginationId}-prev` : "";
const paginationNextId = paginationId ? `${paginationId}-next` : "";
const paginationCurrentId = paginationId ? `${paginationId}-current` : "";
const paginationTotalId = paginationId ? `${paginationId}-total` : "";
const paginationContainerId = paginationId ? `${paginationId}-container` : "";
---

<script
	is:inline
	define:vars={{
		cardSelector,
		listContainerId,
		paginationId,
		paginationPrevId,
		paginationNextId,
		paginationCurrentId,
		paginationTotalId,
		paginationContainerId,
		hiddenClass,
		pageSize,
	}}
>
	function initFlipAnimation() {
		const cards = document.querySelectorAll(cardSelector);
		const listContainer = document.getElementById(listContainerId);
		const paginationContainer = document.getElementById(
			paginationContainerId,
		);
		const prevPageBtn = paginationPrevId
			? document.getElementById(paginationPrevId)
			: null;
		const nextPageBtn = paginationNextId
			? document.getElementById(paginationNextId)
			: null;
		const currentPageSpan = document.getElementById(paginationCurrentId);
		const totalPagesSpan = document.getElementById(paginationTotalId);

		if (!cards.length) {
			return;
		}

		let currentPage = 1;

		if (pageSize > 0) {
			const allCards = Array.from(cards);
			filterItems(false, allCards);
		}

		window.addEventListener("filter-changed", (e) => {
			const { matchedCards } = e.detail;
			currentPage = 1;
			filterItems(false, matchedCards);
		});

		prevPageBtn?.addEventListener("click", () => {
			if (currentPage > 1) {
				currentPage--;
				const matchedCards = Array.from(cards).filter(
					(card) => !card.classList.contains("item-hidden"),
				);
				filterItems(false, matchedCards);
			}
		});

		nextPageBtn?.addEventListener("click", () => {
			const totalPages = parseInt(totalPagesSpan?.textContent || "1");
			if (currentPage < totalPages) {
				currentPage++;
				const matchedCards = Array.from(cards).filter(
					(card) => !card.classList.contains("item-hidden"),
				);
				filterItems(false, matchedCards);
			}
		});

		function filterItems(scrollToTop = false, currentMatchedItems = []) {
			let initialHeight = 0;
			if (listContainer) {
				initialHeight = listContainer.offsetHeight;
				listContainer.style.minHeight = `${initialHeight}px`;
			}

			const itemsToHide = [];
			const itemsToShow = [];
			const itemsToKeep = [];

			cards.forEach((card) => {
				const cardElement = card;
				if (currentMatchedItems.includes(cardElement)) {
				} else {
					if (!cardElement.classList.contains(hiddenClass)) {
						itemsToHide.push(cardElement);
					}
				}
			});

			let visibleOnPage = currentMatchedItems;
			if (pageSize > 0 && currentMatchedItems.length > 0) {
				const totalPages = Math.ceil(
					currentMatchedItems.length / pageSize,
				);
				if (currentPage > totalPages) {
					currentPage = totalPages;
				}
				if (currentPage < 1) {
					currentPage = 1;
				}

				if (paginationContainer) {
					if (currentMatchedItems.length > pageSize) {
						paginationContainer.style.display = "flex";
						if (currentPageSpan) {
							currentPageSpan.textContent =
								currentPage.toString();
						}
						if (totalPagesSpan) {
							totalPagesSpan.textContent = totalPages.toString();
						}
						if (prevPageBtn) {
							prevPageBtn.disabled = currentPage === 1;
						}
						if (nextPageBtn) {
							nextPageBtn.disabled = currentPage === totalPages;
						}
					} else {
						paginationContainer.style.display = "none";
					}
				}

				const startIndex = (currentPage - 1) * pageSize;
				const endIndex = startIndex + pageSize;

				visibleOnPage = currentMatchedItems.slice(startIndex, endIndex);

				currentMatchedItems.forEach((item) => {
					if (!visibleOnPage.includes(item)) {
						if (!item.classList.contains(hiddenClass)) {
							itemsToHide.push(item);
						}
					}
				});
			} else if (paginationContainer) {
				paginationContainer.style.display = "none";
			}

			visibleOnPage.forEach((item) => {
				if (item.classList.contains(hiddenClass)) {
					itemsToShow.push(item);
				} else {
					itemsToKeep.push(item);
				}
			});

			const firstPositions = new Map();
			const itemsToAnimate = [...itemsToKeep, ...itemsToShow];

			itemsToAnimate.forEach((item) => {
				firstPositions.set(item, item.getBoundingClientRect());
			});

			if (paginationContainer) {
				firstPositions.set(
					paginationContainer,
					paginationContainer.getBoundingClientRect(),
				);
			}

			const runAnimation = () => {
				itemsToHide.forEach((item) => {
					item.classList.add(hiddenClass);
					item.classList.remove("flip-fade-out");
				});

				itemsToShow.forEach((item) => {
					item.classList.remove(hiddenClass);
					item.classList.add("flip-fade-in");
					item.style.transition = "none";
					item.style.display = "flex";
				});

				if (listContainer) {
					listContainer.style.minHeight = "";
				}

				const targetPositions = new Map();
				const itemsToMove = [...itemsToKeep];
				if (
					paginationContainer &&
					paginationContainer.style.display !== "none"
				) {
					itemsToMove.push(paginationContainer);
				}
				itemsToMove.forEach((item) => {
					targetPositions.set(item, item.getBoundingClientRect());
				});

				if (listContainer) {
					const currentHeight = listContainer.offsetHeight;
					listContainer.style.minHeight = `${Math.max(initialHeight, currentHeight)}px`;
				}
				const currentPositions = new Map();
				itemsToMove.forEach((item) => {
					currentPositions.set(item, item.getBoundingClientRect());
				});

				itemsToMove.forEach((item) => {
					const first = firstPositions.get(item);
					const current = currentPositions.get(item);
					if (!first || !current) {
						return;
					}

					const deltaX = Math.round(first.left - current.left);
					const deltaY = Math.round(first.top - current.top);

					if (deltaX !== 0 || deltaY !== 0) {
						item.style.willChange = "transform";
						item.style.transition = "none";
						item.style.transform = `translate(${deltaX}px, ${deltaY}px)`;
					}
				});

				requestAnimationFrame(() => {
					requestAnimationFrame(() => {
						itemsToMove.forEach((item) => {
							const target = targetPositions.get(item);
							const current = currentPositions.get(item);
							if (!target || !current) {
								return;
							}

							const finalDeltaX = Math.round(
								target.left - current.left,
							);
							const finalDeltaY = Math.round(
								target.top - current.top,
							);

							item.style.transition =
								"transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
							item.style.transform = `translate(${finalDeltaX}px, ${finalDeltaY}px)`;
						});

						const STAGGER_LIMIT = 20;
						itemsToShow.forEach((item, index) => {
							item.style.willChange = "opacity, transform";
							item.style.transition =
								"opacity 0.5s ease, transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)";
							const delay =
								index < STAGGER_LIMIT ? index * 30 : 0;
							item.style.transitionDelay = `${delay}ms`;
							item.classList.remove("flip-fade-in");
							item.classList.add("flip-fade-in-active");
						});
					});

					const cleanupDelay =
						600 +
						(itemsToShow.length > 0
							? Math.min(itemsToShow.length, 20) * 30
							: 0);
					setTimeout(() => {
						[...itemsToMove, ...itemsToShow].forEach((item) => {
							item.classList.remove("flip-fade-in-active");
							item.style.transition = "";
							item.style.transform = "";
							item.style.opacity = "";
							item.style.willChange = "";
							item.style.transitionDelay = "";
						});

						if (listContainer) {
							listContainer.style.minHeight = "";
						}
					}, cleanupDelay);
				});

				if (scrollToTop && visibleOnPage.length > 0) {
					const listTop =
						document
							.getElementById(listContainerId)
							?.getBoundingClientRect().top || 0;
					const offset = window.pageYOffset + listTop - 100;
					window.scrollTo({
						top: offset,
						behavior: "smooth",
					});
				}
			};

			if (itemsToHide.length > 0) {
				itemsToHide.forEach((item) => {
					item.classList.add("flip-fade-out");
				});
				setTimeout(runAnimation, 200);
			} else {
				runAnimation();
			}
		}
	}

	document.addEventListener("astro:page-load", initFlipAnimation);
</script>

<style>
	:global(.flip-fade-out) {
		opacity: 0 !important;
		transform: scale(0.9) !important;
		pointer-events: none;
	}

	:global(.flip-fade-in) {
		opacity: 0 !important;
		transform: scale(0.9) !important;
	}

	:global(.flip-fade-in-active) {
		opacity: 1 !important;
		transform: scale(1) !important;
	}

	:global(.flip-hidden) {
		display: none !important;
	}

	@media (max-width: 768px) {
		:global(.flip-card) {
			-webkit-transform: translateZ(0);
			transform: translateZ(0);
			-webkit-backface-visibility: hidden;
			backface-visibility: hidden;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		:global(.flip-card) {
			transition-duration: 0.15s !important;
		}
	}
</style>
