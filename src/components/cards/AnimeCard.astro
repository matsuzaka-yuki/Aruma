---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

interface Props {
	title: string;
	cover: string;
	link: string;
	description: string;
	year: string;
	studio: string;
	progress: number;
	totalEpisodes: number;
	status?: string;
}

const {
	title,
	cover,
	link,
	description,
	year,
	studio,
	progress,
	totalEpisodes,
	status,
} = Astro.props;
const progressPercent =
	totalEpisodes > 0 ? (progress / totalEpisodes) * 100 : 0;

// Map status to i18n key
const statusI18nMap: Record<string, I18nKey> = {
	watching: I18nKey.watching,
	completed: I18nKey.completed,
	planned: I18nKey.planned,
	onhold: I18nKey.animeStatusOnHold,
	dropped: I18nKey.animeStatusDropped,
};

// Status color classes (Mizuki style - light bg with colored text, dark mode variants)
const statusColorMap: Record<string, { light: string; dark: string }> = {
	watching: {
		light: "bg-green-100 text-green-700",
		dark: "dark:bg-green-900/30 dark:text-green-300",
	},
	completed: {
		light: "bg-blue-100 text-blue-700",
		dark: "dark:bg-blue-900/30 dark:text-blue-300",
	},
	planned: {
		light: "bg-amber-100 text-amber-700",
		dark: "dark:bg-amber-900/30 dark:text-amber-300",
	},
	onhold: {
		light: "bg-purple-100 text-purple-700",
		dark: "dark:bg-purple-900/30 dark:text-purple-300",
	},
	dropped: {
		light: "bg-red-100 text-red-700",
		dark: "dark:bg-red-900/30 dark:text-red-300",
	},
};

const displayStatus =
	status && statusI18nMap[status]
		? {
				label: i18n(statusI18nMap[status]),
				colors: statusColorMap[status] || statusColorMap.planned,
			}
		: null;
---

<article
	class="mdui-card anime-card mdui-hoverable flex flex-row rounded-xl transition-all duration-300 overflow-hidden hover:-translate-y-1 hover:shadow-lg"
	data-status={status}
>
	<div
		class="anime-cover w-32 md:w-44 flex-shrink-0 overflow-hidden relative aspect-[2/3]"
	>
		<a
			href={link}
			target="_blank"
			rel="noopener noreferrer"
			class="block w-full h-full"
		>
			<img
				src={cover}
				alt={title}
				loading="lazy"
				decoding="async"
				fetchpriority="low"
				referrerpolicy="no-referrer"
				class="w-full h-full object-cover opacity-0 transition-opacity duration-300"
				onload="this.classList.remove('opacity-0')"
			/>
			<div class="anime-cover-overlay">
				{
					displayStatus && (
						<span
							class={`anime-status-tag absolute top-2 left-2 z-10 inline-flex items-center px-2 py-1 rounded-md text-xs font-medium shadow-md ${displayStatus.colors.light} ${displayStatus.colors.dark}`}
						>
							{displayStatus.label}
						</span>
					)
				}
				<div class="anime-play-button">
					<svg
						class="w-6 h-6"
						fill="currentColor"
						viewBox="0 0 24 24"
					>
						<path d="M8 5v14l11-7z"></path>
					</svg>
				</div>
				{
					status === "watching" && (
						<div class="anime-cover-progress absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 to-transparent p-2">
							<div class="w-full bg-white/20 rounded-full h-1.5 mb-1">
								<div
									class="bg-gradient-to-r from-emerald-400 to-teal-400 h-1.5 rounded-full transition-all duration-300"
									style={`width: ${progressPercent}%`}
								/>
							</div>
							<div class="text-white text-xs font-medium">
								{progress}/{totalEpisodes} (
								{Math.round(progressPercent)}%)
							</div>
						</div>
					)
				}
			</div>
		</a>
	</div>

	<div
		class="anime-content flex-1 min-w-0 p-4 md:p-5 flex flex-col justify-between min-h-[160px]"
	>
		<h3 class="anime-title text-lg font-medium line-clamp-2 leading-snug">
			{title}
		</h3>
		{
			description && (
				<p class="anime-description text-sm line-clamp-4 leading-relaxed">
					{description}
				</p>
			)
		}

		<div class="anime-meta-container">
			<div
				class="anime-meta-row flex justify-between items-center text-xs mb-1"
			>
				<span class="anime-meta-label flex-shrink-0">
					{i18n(I18nKey.animeYear)}
				</span>
				<span
					class="anime-meta-value text-right ml-3 overflow-hidden text-ellipsis whitespace-nowrap"
				>
					{year}
				</span>
			</div>
			<div
				class="anime-meta-row flex justify-between items-center text-xs"
			>
				<span class="anime-meta-label flex-shrink-0">
					{i18n(I18nKey.animeStudio)}
				</span>
				<span
					class="anime-meta-value text-right ml-3 overflow-hidden text-ellipsis whitespace-nowrap"
				>
					{studio}
				</span>
			</div>
		</div>
	</div>
</article>

<style>
	.mdui-card.anime-card {
		background: var(--archive-card-bg);
	}

	.anime-cover img {
		transition:
			opacity 0.3s ease-in-out,
			transform 0.5s ease;
	}

	.anime-card:hover .anime-cover img {
		transform: scale(1.1);
	}

	.anime-cover-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.anime-play-button {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.9);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--mdui-color-primary, #ff4081);
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.anime-card:hover .anime-play-button {
		opacity: 1;
	}

	.anime-status-tag {
		pointer-events: none;
	}

	:global(.mdui-theme-layout-dark) .anime-title {
		color: #fff;
	}

	:global(.mdui-theme-layout-dark) .anime-description {
		color: rgba(255, 255, 255, 0.7);
	}

	:global(.mdui-theme-layout-dark) .anime-meta-label {
		color: rgba(255, 255, 255, 0.6);
	}

	:global(.mdui-theme-layout-dark) .anime-meta-value {
		color: rgba(255, 255, 255, 0.7);
	}
</style>
