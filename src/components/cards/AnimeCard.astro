---
import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

interface Props {
	title: string;
	cover: string;
	link: string;
	description: string;
	year: string;
	studio: string;
	progress: number;
	totalEpisodes: number;
	status?: string;
}

const {
	title,
	cover,
	link,
	description,
	year,
	studio,
	progress,
	totalEpisodes,
	status,
} = Astro.props;
const progressPercent =
	totalEpisodes > 0 ? (progress / totalEpisodes) * 100 : 0;
---

<article
	class="mdui-card anime-card mdui-hoverable flex flex-row rounded-xl transition-all duration-300 overflow-hidden hover:-translate-y-1 hover:shadow-lg"
	data-status={status}
>
	<div
		class="anime-cover w-32 md:w-44 flex-shrink-0 overflow-hidden relative"
	>
		<a
			href={link}
			target="_blank"
			rel="noopener noreferrer"
			class="block w-full h-full"
		>
			<img
				src={cover}
				alt={title}
				loading="lazy"
				referrerpolicy="no-referrer"
				class="w-full h-full object-cover transition-transform duration-500 hover:scale-110"
			/>
			<div class="anime-cover-overlay">
				<div class="anime-play-button">
					<svg
						class="w-6 h-6"
						fill="currentColor"
						viewBox="0 0 24 24"
					>
						<path d="M8 5v14l11-7z"></path>
					</svg>
				</div>
			</div>
		</a>
	</div>

	<div
		class="anime-content flex-1 min-w-0 p-4 md:p-5 flex flex-col justify-between"
	>
		<div class="anime-header">
			<h3
				class="anime-title text-lg font-medium mb-1.5 line-clamp-2 leading-snug"
			>
				{title}
			</h3>
			<p class="anime-description text-sm line-clamp-3 leading-relaxed">
				{description}
			</p>
		</div>

		<div class="anime-meta-container">
			<div
				class="anime-meta-row flex justify-between items-center text-xs mb-1"
			>
				<span class="anime-meta-label flex-shrink-0">
					{i18n(I18nKey.animeYear)}
				</span>
				<span
					class="anime-meta-value text-right ml-3 overflow-hidden text-ellipsis whitespace-nowrap"
				>
					{year}
				</span>
			</div>
			<div
				class="anime-meta-row flex justify-between items-center text-xs"
			>
				<span class="anime-meta-label flex-shrink-0">
					{i18n(I18nKey.animeStudio)}
				</span>
				<span
					class="anime-meta-value text-right ml-3 overflow-hidden text-ellipsis whitespace-nowrap"
				>
					{studio}
				</span>
			</div>
		</div>

		<div class="anime-progress-container">
			<div
				class="anime-progress-bar w-full h-1 rounded-full overflow-hidden mb-1"
			>
				<div
					class="anime-progress-fill h-full bg-gradient-to-r from-green-500 to-green-400 rounded-full transition-all duration-300"
					style={`width: ${progressPercent}%`}
				>
				</div>
			</div>
			<span class="anime-progress-text text-xs">
				{progress}/{totalEpisodes} ({Math.round(progressPercent)}%)
			</span>
		</div>
	</div>
</article>

<style>
	.mdui-card.anime-card {
		background: var(--archive-card-bg);
	}

	.anime-progress-bar {
		background: #e5e7eb;
	}

	.anime-cover-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(to top, rgba(0, 0, 0, 0.6), transparent);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.anime-card:hover .anime-cover-overlay {
		opacity: 1;
	}

	.anime-play-button {
		width: 2.5rem;
		height: 2.5rem;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.9);
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--mdui-color-primary, #ff4081);
	}

	:global(.mdui-theme-layout-dark) .anime-title {
		color: #fff;
	}

	:global(.mdui-theme-layout-dark) .anime-description {
		color: rgba(255, 255, 255, 0.7);
	}

	:global(.mdui-theme-layout-dark) .anime-meta-label {
		color: rgba(255, 255, 255, 0.6);
	}

	:global(.mdui-theme-layout-dark) .anime-meta-value {
		color: rgba(255, 255, 255, 0.7);
	}

	:global(.mdui-theme-layout-dark) .anime-progress-bar {
		background: rgba(255, 255, 255, 0.15);
	}

	:global(.mdui-theme-layout-dark) .anime-progress-text {
		color: rgba(255, 255, 255, 0.6);
	}
</style>
