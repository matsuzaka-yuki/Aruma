---
import { i18n } from "../../i18n/translation";
import I18nKey from "../../i18n/i18nKey";
import IconWrapper from "../IconWrapper.svelte";

interface Props {
	name: string;
	icon: string;
	level: "beginner" | "intermediate" | "advanced" | "expert";
	description: string;
	category: "frontend" | "backend" | "database" | "tools" | "other";
	experience?: {
		years: number;
		months: number;
	};
}
const { name, icon, level, description, category, experience } = Astro.props;

// 技能等级进度和颜色
const getLevelInfo = (level: string) => {
	switch (level) {
		case "expert":
			return { percent: 100, label: i18n(I18nKey.skillsExpert), color: "bg-red-500" };
		case "advanced":
			return { percent: 80, label: i18n(I18nKey.skillsAdvanced), color: "bg-orange-500" };
		case "intermediate":
			return { percent: 60, label: i18n(I18nKey.skillsIntermediate), color: "bg-blue-500" };
		case "beginner":
			return { percent: 30, label: i18n(I18nKey.skillsBeginner), color: "bg-green-500" };
		default:
			return { percent: 0, label: level, color: "bg-gray-500" };
	}
};

// 格式化经验时间（参考Mizuki风格）
const formatExperience = (exp: { years: number; months: number }) => {
	const parts: string[] = [];
	if (exp.years > 0) {
		parts.push(`${exp.years} ${i18n(I18nKey.skillYears)}`);
	}
	if (exp.months > 0) {
		parts.push(`${exp.months} ${i18n(I18nKey.skillMonths)}`);
	}
	return parts.join(" ");
};

const levelInfo = getLevelInfo(level);
---

<div
	class="mdui-card skill-card mdui-hoverable p-5 rounded-xl transition-all duration-300 flex flex-col gap-4 border border-transparent hover:border-theme hover:shadow-lg"
	data-category={category}
>
	<div class="skill-header flex items-center gap-4">
		<div class="skill-icon-container w-12 h-12 flex items-center justify-center bg-gray-100 rounded-lg overflow-hidden">
			<IconWrapper client:load icon={icon} size="2rem" />
		</div>
		<div class="skill-title-container flex-1">
			<h3 class="skill-name text-lg font-bold text-gray-800 m-0">
				{name}
			</h3>
			<div class="skill-level-badge inline-block text-[10px] px-2 py-0.5 rounded-full bg-theme/10 text-theme font-medium uppercase tracking-wider">
				{levelInfo.label}
			</div>
		</div>
	</div>

	<p class="skill-description text-sm text-gray-600 m-0 line-clamp-2 leading-relaxed min-h-[2.5rem]">
		{description}
	</p>

	<div class="skill-footer mt-auto">
		{experience && (
			<div class="skill-experience-display flex justify-between items-center text-[10px] text-gray-500 mb-1">
				<span>{i18n(I18nKey.skillExperience)}</span>
				<span class="font-medium">{formatExperience(experience)}</span>
			</div>
		)}
		<div class="skill-progress-bar w-full h-1.5 bg-gray-200 rounded-full overflow-hidden">
			<div
				class={`skill-progress-fill h-full ${levelInfo.color} transition-all duration-500 ease-out`}
				style={`width: ${levelInfo.percent}%`}
			></div>
		</div>
	</div>
</div>

<style>
	.skill-card {
		height: 100%;
		box-sizing: border-box;
		background-color: var(--card-bg);
	}

	.skill-description {
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	:global(.mdui-theme-layout-dark) .skill-name {
		color: #fff;
	}

	:global(.mdui-theme-layout-dark) .skill-description {
		color: rgba(255, 255, 255, 0.7);
	}

	:global(.mdui-theme-layout-dark) .skill-icon-container {
		background-color: rgba(255, 255, 255, 0.1);
	}

	:global(.mdui-theme-layout-dark) .skill-progress-bar {
		background-color: rgba(255, 255, 255, 0.1);
	}

	:global(.mdui-theme-layout-dark) .skill-experience-display span {
		color: rgba(255, 255, 255, 0.5);
	}

	.bg-theme {
		background-color: var(--color, #ff4081);
	}
	.text-theme {
		color: var(--color, #ff4081);
	}
	.bg-theme\/10 {
		background-color: color-mix(in srgb, var(--color, #ff4081) 10%, transparent);
	}
	.border-theme {
		border-color: color-mix(in srgb, var(--color, #ff4081) 20%, transparent);
	}
</style>
