---
import "../../styles/albums.css";

import I18nKey from "../../i18n/i18nKey";
import { i18n } from "../../i18n/translation";

interface Props {
	id: string;
	title: string;
	description?: string;
	cover: string;
	photos: number;
	date: string;
	location?: string;
	tags?: string[];
}

const {
	id,
	title,
	description,
	cover,
	photos,
	date,
	location,
	tags = [],
} = Astro.props;
---

<article class="album-card mdui-card mdui-hoverable">
	<a href={`/albums/${id}/`} class="album-card-link">
		<div class="album-cover">
			<img
				src={cover}
				alt={title}
				loading="lazy"
				class="w-full h-full object-cover transition-transform duration-500 hover:scale-110"
			/>
			<div class="album-cover-overlay"></div>
		</div>

		<div class="album-info p-5 flex flex-col flex-1">
			<h3 class="album-title text-xl font-medium mb-2.5 truncate">
				{title}
			</h3>

			{
				description && (
					<p class="album-description text-sm mb-3.5 line-clamp-2 leading-relaxed">
						{description}
					</p>
				)
			}

			<div class="album-meta flex flex-wrap gap-3.5 text-xs mt-auto">
				<span class="album-count flex items-center gap-1">
					<i class="mdui-icon material-icons w-4 h-4 text-base"
						>photo</i
					>
					{photos}
					{
						photos > 1
							? i18n(I18nKey.albumsPhotosCount)
							: i18n(I18nKey.albumsPhotoCount)
					}
				</span>

				<time class="album-date flex items-center gap-1">
					<i class="mdui-icon material-icons w-4 h-4 text-base"
						>event</i
					>
					{new Date(date).toLocaleDateString("zh-CN")}
				</time>

				{
					location && (
						<span class="album-location flex items-center gap-1">
							<i class="mdui-icon material-icons w-4 h-4 text-base">
								location_on
							</i>
							{location}
						</span>
					)
				}
			</div>

			{
				tags.length > 0 && (
					<div class="album-tags flex flex-wrap gap-1.5 mt-3">
						{tags.slice(0, 4).map((tag) => (
							<span class="album-tag inline-block px-2.5 py-0.75 rounded-3 text-xs transition-all duration-200 hover:-translate-y-0.25">
								{tag}
							</span>
						))}
						{tags.length > 4 && (
							<span class="album-tag-more inline-block px-2.5 py-0.75 rounded-3 text-xs">
								+{tags.length - 4}
							</span>
						)}
					</div>
				)
			}
		</div>
	</a>
</article>

<style>
	/* 夜间模式样式 - 确保优先级 */
	:global(.mdui-theme-layout-dark) .album-title {
		color: #fff;
	}

	:global(.mdui-theme-layout-dark) .album-description {
		color: rgba(255, 255, 255, 0.7);
	}

	:global(.mdui-theme-layout-dark) .album-meta {
		color: rgba(255, 255, 255, 0.6);
	}

	:global(.mdui-theme-layout-dark) .album-tag {
		background-color: var(--album-tag-bg);
		color: var(--color);
	}

	:global(.mdui-theme-layout-dark) .album-tag:hover {
		background-color: var(--album-tag-hover-bg);
	}

	:global(.mdui-theme-layout-dark) .album-tag-more {
		color: rgba(255, 255, 255, 0.7);
		background-color: var(--album-tag-more-bg);
	}
</style>
