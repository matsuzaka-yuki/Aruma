---
import { siteConfig } from '../site.config';
import { getCollection } from 'astro:content';
import { i18n } from '../i18n/translation';
import I18nKey from '../i18n/i18nKey';

// Helper to map social icons
const getSocialIcon = (name: string) => {
  const map: Record<string, string> = {
    GitHub: 'code',
    Twitter: 'share',
    Email: 'email',
  };
  return map[name] || 'link';
};

const posts = await getCollection('post');

const categoryCounts = posts.reduce((acc, post) => {
  const category = post.data.category?.trim();
  if (!category) return acc;
  acc[category] = (acc[category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const categories = Object.entries(categoryCounts)
  .map(([name, count]) => ({
    name,
    count,
    slug: encodeURIComponent(name)
  }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'zh'));

const archiveCounts = posts.reduce((acc, post) => {
  const year = post.data.pubDate.getFullYear();
  acc[year] = (acc[year] || 0) + 1;
  return acc;
}, {} as Record<number, number>);

const archives = Object.entries(archiveCounts)
  .map(([year, count]) => ({
    year: Number(year),
    count
  }))
  .sort((a, b) => b.year - a.year);
---

<div class="mdui-appbar mdui-shadow-0 mdui-appbar-fixed mdui-appbar-scroll-hide">
  <div class="mdui-toolbar">
    <a class="mdui-btn mdui-btn-icon" id="toggle-drawer">
      <i class="mdui-icon material-icons">menu</i>
    </a>
    <a href="/" class="mdui-typo-title">{siteConfig.title}</a>
    <div class="mdui-toolbar-spacer"></div>
    <div class="mdui-textfield mdui-textfield-expandable appbar-search" id="search-container">
      <button class="mdui-textfield-icon mdui-btn mdui-btn-icon" id="open-search">
        <i class="mdui-icon material-icons">search</i>
      </button>
      <input class="mdui-textfield-input" type="text" id="search-input" placeholder={i18n(I18nKey.searchPlaceholder)} autocomplete="off" />
    </div>
    <mdui-dropdown id="qrcode-dropdown" trigger="click" placement="bottom-end">
      <button class="mdui-btn mdui-btn-icon" slot="trigger" id="open-qrcode">
        <i class="mdui-icon material-icons">devices</i>
      </button>
      <div class="qrcode-container">
        <canvas id="qrcode-canvas"></canvas>
      </div>
    </mdui-dropdown>
    <button id="toggle-dark-mode" class="mdui-btn mdui-btn-icon">
      <i class="mdui-icon material-icons" id="dark-mode-icon">brightness_5</i>
    </button>
  </div>
</div>


<div id="drawer-overlay" class="drawer-overlay"></div>

<div class="mdui-drawer mdui-drawer-close mdui-drawer-full-height drawer" id="main-drawer">
  <div class="drawer-profile">
    <div class="drawer-avatar">
      <img src={siteConfig.avatar} alt="Avatar"/>
    </div>
    <div class="drawer-social">
      {siteConfig.social.map(s => (
        <a href={s.url} target="_blank" class="social-icon" title={s.name}>
          <i class="mdui-icon material-icons">{getSocialIcon(s.name)}</i>
        </a>
      ))}
    </div>
  </div>

  <div class="mdui-divider"></div>

  <div class="mdui-list" id="drawer-menu">
    {siteConfig.nav.map(item => {
      // @ts-ignore
      if (item.type === 'divider') {
        return <div class="mdui-divider"></div>;
      }

      // @ts-ignore
      if (item.type === 'category') {
        return (
          <div class="mdui-collapse-item">
            <div class="mdui-collapse-item-header mdui-list-item mdui-ripple">
              {/* @ts-ignore */}
              <i class="mdui-list-item-icon mdui-icon material-icons">{item.icon || 'widgets'}</i>
              {/* @ts-ignore */}
              <div class="mdui-list-item-content">{item.name || i18n(I18nKey.category)}</div>
              <i class="mdui-collapse-item-arrow mdui-icon material-icons">keyboard_arrow_down</i>
            </div>
            <div class="mdui-collapse-item-body">
              {categories.map((category) => (
                <a href={`/category/${category.slug}`} class="mdui-list-item mdui-ripple">
                  <div class="mdui-list-item-content">{category.name}</div>
                  <span class="drawer-count">{category.count}</span>
                </a>
              ))}
            </div>
          </div>
        );
      }

      // @ts-ignore
      if (item.type === 'archive') {
        return (
          <div class="mdui-collapse-item">
            <div class="mdui-collapse-item-header mdui-list-item mdui-ripple">
              {/* @ts-ignore */}
              <i class="mdui-list-item-icon mdui-icon material-icons">{item.icon || 'access_time'}</i>
              {/* @ts-ignore */}
              <div class="mdui-list-item-content">{item.name || i18n(I18nKey.archive)}</div>
              <i class="mdui-collapse-item-arrow mdui-icon material-icons">keyboard_arrow_down</i>
            </div>
            <div class="mdui-collapse-item-body">
              {archives.map((archive) => (
                <a href={`/archive#year-${archive.year}`} class="mdui-list-item mdui-ripple" data-archive-link data-year={archive.year}>
                  <div class="mdui-list-item-content">{archive.year}</div>
                  <span class="drawer-count">{archive.count}</span>
                </a>
              ))}
            </div>
          </div>
        );
      }

      // @ts-ignore
      return item.children ? (
        <div class="mdui-collapse-item">
          <div class="mdui-collapse-item-header mdui-list-item mdui-ripple">
            {/* @ts-ignore */}
            <i class="mdui-list-item-icon mdui-icon material-icons">{item.icon || 'folder'}</i>
            {/* @ts-ignore */}
            <div class="mdui-list-item-content">{I18nKey[item.name.toLowerCase() as keyof typeof I18nKey] ? i18n(I18nKey[item.name.toLowerCase() as keyof typeof I18nKey]) : item.name}</div>
            <i class="mdui-collapse-item-arrow mdui-icon material-icons">keyboard_arrow_down</i>
          </div>
          <div class="mdui-collapse-item-body">
            {/* @ts-ignore */}
            {item.children.map(child => (
               <a href={child.path} class="mdui-list-item mdui-ripple">
                 <div class="mdui-list-item-content">{I18nKey[child.name?.toLowerCase() as keyof typeof I18nKey] ? i18n(I18nKey[child.name?.toLowerCase() as keyof typeof I18nKey]) : child.name}</div>
               </a>
            ))}
          </div>
        </div>
      ) : (
        // @ts-ignore
        <a href={item.path} class="mdui-list-item mdui-ripple">
            {/* @ts-ignore */}
            <i class="mdui-list-item-icon mdui-icon material-icons">{item.icon || 'link'}</i>
            {/* @ts-ignore */}
            <div class="mdui-list-item-content">{I18nKey[item.name.toLowerCase() as keyof typeof I18nKey] ? i18n(I18nKey[item.name.toLowerCase() as keyof typeof I18nKey]) : item.name}</div>
        </a>
      );
    })}
  </div>

  <div class="drawer-bottom">
    <a href="/rss.xml" class="mdui-list-item mdui-ripple">
       <i class="mdui-list-item-icon mdui-icon material-icons">rss_feed</i>
       <div class="mdui-list-item-content">{i18n(I18nKey.rssSubscribe)}</div>
    </a>
  </div>
</div>

<style>
  /* Drawer Styles */
  .drawer {
    background: var(--drawer-bg);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-right: 1px solid rgba(0,0,0,0.05);
    display: flex;
    flex-direction: column;
  }

  /* Profile Section */
  .drawer-profile {
    padding: 20px 0 10px; /* 进一步压缩间距 */
    text-align: center;
    background: transparent;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .drawer-avatar, .drawer-social {
    position: relative;
    z-index: 1;
  }
  .drawer-avatar img {
    width: 120px; /* 稍微缩小一点头像以适应更紧凑的布局 */
    height: 120px;
    border-radius: 50%;
    border: 3px solid rgba(0, 0, 0, 0.1); /* 白天模式下使用浅色边框 */
    box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    transition: transform 0.3s;
    object-fit: cover;
  }
  :global(.mdui-theme-layout-dark) .drawer-avatar img {
    border-color: rgba(255, 255, 255, 0.2);
  }
  .drawer-avatar img:hover {
    transform: rotate(360deg);
  }
  .drawer-social {
    margin-top: 12px; /* 减小间距 */
    display: flex;
    justify-content: center;
    gap: 15px;
  }
  .social-icon {
    color: #000; /* 白天模式纯黑 */
    transition: all 0.3s;
  }
  .social-icon:hover {
    color: var(--color);
    transform: scale(1.1);
  }
  :global(.mdui-theme-layout-dark) .social-icon {
    color: rgba(255, 255, 255, 0.6);
  }

  /* List Colors for Light Mode */
  .drawer .mdui-list-item {
    color: #000; /* 文本纯黑 */
    transition: background-color 0.25s ease, transform 0.2s ease;
    border-radius: 4px;
    flex-shrink: 0;
  }
  .drawer .mdui-list-item-icon {
    color: #000; /* 图标纯黑 */
  }
  :global(.mdui-theme-layout-dark) .drawer .mdui-list-item,
  :global(.mdui-theme-layout-dark) .drawer .mdui-list-item-icon {
    color: inherit; /* 恢复暗色模式默认 */
  }

  .drawer .mdui-list-item:hover {
    background-color: rgba(0, 0, 0, 0.06);
  }
  .drawer .mdui-list-item:active {
    transform: scale(0.98);
  }
  :global(.mdui-theme-layout-dark) .drawer .mdui-list-item:hover {
    background-color: rgba(255, 255, 255, 0.08);
  }

  /* Overlay */
  .drawer-overlay {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
    z-index: 2999;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s;
    backdrop-filter: blur(2px);
  }
  .drawer-overlay.show {
    opacity: 1;
    visibility: visible;
  }

  /* Nested List Styles */
  .mdui-collapse-item-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s ease;
    padding: 0;
    margin: 0;
  }
  .mdui-collapse-item-arrow {
    transition: transform 0.3s;
  }
  .mdui-collapse-item.open .mdui-collapse-item-arrow {
    transform: rotate(180deg);
  }
  .mdui-collapse-item-body .mdui-list-item {
    padding-left: 56px;
    font-size: 14px;
    height: 40px;
  }
  .mdui-collapse-item-body .mdui-list-item-content {
    opacity: 0.8;
  }
  .drawer-count {
    margin-left: auto;
    background: rgba(0, 0, 0, 0.08);
    color: #000;
    font-size: 12px;
    padding: 2px 6px;
    border-radius: 4px;
    min-width: 18px;
    text-align: center;
  }
  :global(.mdui-theme-layout-dark) .drawer-count {
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.8);
  }

  .drawer-rss {
    width: 100%;
  }
  .drawer-bottom {
    position: absolute;
    bottom: 0;
    width: 100%;
    border-top: 1px solid rgba(0,0,0,0.05);
  }
  :global(.mdui-theme-layout-dark) .drawer {
    border-right-color: rgba(255, 255, 255, 0.05);
  }
  :global(.mdui-theme-layout-dark) .drawer-bottom {
    border-top-color: rgba(255, 255, 255, 0.05);
  }

  /* 展开式搜索框 */
  .appbar-search {
    position: relative;
    display: flex;
    align-items: center;
  }

  .appbar-search .mdui-textfield-input {
    color: rgba(255, 255, 255, 0.87);
    border-bottom: 1px solid rgba(255, 255, 255, 0.42);
    width: 0;
    transition: width 0.3s ease;
    background: transparent;
    border-top: none;
    border-left: none;
    border-right: none;
    padding: 8px 0;
    font-size: 16px;
    outline: none;
    box-shadow: none;
  }

  .appbar-search .mdui-textfield-input:focus {
    outline: none;
    box-shadow: none;
    border-bottom: 1px solid #fff;
  }

  .appbar-search.mdui-textfield-expanded .mdui-textfield-input {
    width: 200px;
    border-bottom-color: #fff;
  }

  .appbar-search .mdui-textfield-input::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }

  /* 手机端响应式 */
  @media (max-width: 768px) {
    .appbar-search.mdui-textfield-expanded .mdui-textfield-input {
      width: 120px;
    }
  }

  @media (max-width: 480px) {
    .appbar-search.mdui-textfield-expanded .mdui-textfield-input {
      width: 100px;
    }
  }

  /* QR Code Styles */
  .qrcode-container {
    padding: 12px;
    background: #fff; /* Use solid white for light mode */
    border: 3px solid var(--mdui-color-primary);
    border-radius: 16px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateY(-10px);
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  :global(.mdui-theme-layout-dark) .qrcode-container {
    background: #303030; /* Use solid dark grey for dark mode */
    border-color: var(--mdui-color-primary);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  }

  /* Trigger animation when dropdown is open */
  mdui-dropdown[open] .qrcode-container {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  #qrcode-canvas {
    background: #fff;
    border-radius: 8px;
    width: 150px;
    height: 150px;
  }

  /* Remove MDUI 2 default dropdown styles to let our container handle everything */
  mdui-dropdown#qrcode-dropdown::part(panel) {
    background: transparent;
    box-shadow: none;
    overflow: visible;
  }

  @media (max-width: 600px) {
    #qrcode-dropdown {
      display: none;
    }
  }
</style>

<script>
  import QRCode from 'qrcode';
  import { navigate } from 'astro:transitions/client';

  function initHeader() {
    try {
      const toggleBtn = document.getElementById('toggle-drawer');
      const drawer = document.getElementById('main-drawer');
      const overlay = document.getElementById('drawer-overlay');

      // QR Code logic
      const qrcodeDropdown = document.getElementById('qrcode-dropdown') as any;
      const qrcodeCanvas = document.getElementById('qrcode-canvas') as HTMLCanvasElement;

      if (qrcodeDropdown && qrcodeCanvas && !qrcodeDropdown.dataset.bound) {
        qrcodeDropdown.dataset.bound = 'true';
        qrcodeDropdown.addEventListener('open', () => {
          const url = window.location.href;
          QRCode.toCanvas(qrcodeCanvas, url, {
            width: 150,
            margin: 0,
            color: {
              dark: '#000000',
              light: '#ffffff'
            }
          }, (error) => {
            if (error) console.error('Failed to generate QR code:', error);
          });
        });
      }

      function openDrawer() {
        drawer?.classList.add('mdui-drawer-open');
        overlay?.classList.add('show');
        document.body.style.overflow = 'hidden';
      }

      function closeDrawer() {
        drawer?.classList.remove('mdui-drawer-open');
        overlay?.classList.remove('show');
        document.body.style.overflow = '';
      }

      if (toggleBtn && !toggleBtn.dataset.bound) {
        toggleBtn.dataset.bound = 'true';
        toggleBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          if (drawer?.classList.contains('mdui-drawer-open')) {
            closeDrawer();
          } else {
            openDrawer();
          }
        });
      }

      if (overlay && !overlay.dataset.bound) {
        overlay.dataset.bound = 'true';
        overlay.addEventListener('click', closeDrawer);
      }

      const collapseItems = document.querySelectorAll('.mdui-collapse-item');
      collapseItems.forEach(item => {
        const header = item.querySelector('.mdui-collapse-item-header');
        const body = item.querySelector('.mdui-collapse-item-body');

        if (header && body && !(header as HTMLElement).dataset.bound) {
          (header as HTMLElement).dataset.bound = 'true';
          header.addEventListener('click', (e) => {
            e.stopPropagation();
            const isOpen = item.classList.contains('open');

            collapseItems.forEach(otherItem => {
              if (otherItem !== item && otherItem.classList.contains('open')) {
                 otherItem.classList.remove('open');
                 const otherBody = otherItem.querySelector('.mdui-collapse-item-body');
                 if (otherBody) {
                   // @ts-ignore
                   otherBody.style.maxHeight = '0';
                 }
              }
            });

            if (isOpen) {
              item.classList.remove('open');
              // @ts-ignore
              body.style.maxHeight = '0';
            } else {
              item.classList.add('open');
              // @ts-ignore
              body.style.maxHeight = body.scrollHeight + 'px';
            }
          });
        }
      });

      // Handle archive links specially to fix hash navigation with View Transitions
      const archiveLinks = document.querySelectorAll('[data-archive-link]');
      archiveLinks.forEach((link) => {
        if (!(link as HTMLElement).dataset.bound) {
          (link as HTMLElement).dataset.bound = 'true';
          link.addEventListener('click', (e) => {
            e.preventDefault();
            const year = (link as HTMLElement).dataset.year;
            const targetHash = `#year-${year}`;

            // Check if we're already on the archive page
            const isOnArchivePage = window.location.pathname === '/archive' || window.location.pathname === '/archive/';

            if (isOnArchivePage) {
              // Already on archive page, just update hash and trigger filter
              window.location.hash = targetHash;
              // Trigger the global archive filter function if available
              if ((window as any).applyArchiveFilter) {
                (window as any).applyArchiveFilter(targetHash);
              }
              // Close drawer
              closeDrawer();
            } else {
              // Navigate to archive page with hash
              closeDrawer();
              navigate(`/archive${targetHash}`);
            }
          });
        }
      });

      const darkModeBtn = document.getElementById('toggle-dark-mode');
      const darkModeIcon = document.getElementById('dark-mode-icon');
      const html = document.documentElement;

      if (darkModeBtn && !darkModeBtn.dataset.bound) {
        darkModeBtn.dataset.bound = 'true';
        darkModeBtn.addEventListener('click', () => {
          if (html.classList.contains('mdui-theme-layout-dark')) {
            html.classList.remove('mdui-theme-layout-dark');
            localStorage.setItem('theme', 'light');
            if (darkModeIcon) darkModeIcon.innerText = 'brightness_5';
          } else {
            html.classList.add('mdui-theme-layout-dark');
            localStorage.setItem('theme', 'dark');
            if (darkModeIcon) darkModeIcon.innerText = 'brightness_4';
          }
        });
      }

      // 搜索功能
      const searchContainer = document.getElementById('search-container');
      const openSearchBtn = document.getElementById('open-search');
      const searchInput = document.getElementById('search-input') as HTMLInputElement;

      const openSearch = () => {
        if (!searchContainer) return;
        searchContainer.classList.add('mdui-textfield-expanded');
        if (typeof closeDrawer === 'function') closeDrawer();
        if (searchInput) {
          searchInput.value = '';
          searchInput.focus();
        }
      };

      const closeSearch = () => {
        if (!searchContainer) return;
        searchContainer.classList.remove('mdui-textfield-expanded');
      };

      const performSearch = () => {
        const query = searchInput.value.trim();
        if (query) {
          // 使用 Astro navigate 进行平滑导航
          navigate(`/post/?q=${encodeURIComponent(query)}`);
        }
      };

      // 点击搜索按钮逻辑
      if (openSearchBtn && !openSearchBtn.dataset.bound) {
        openSearchBtn.dataset.bound = 'true';
        openSearchBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          const hasContent = searchInput && searchInput.value.trim().length > 0;
          if (searchContainer?.classList.contains('mdui-textfield-expanded') || hasContent) {
            // 如果已展开或有内容，执行搜索
            performSearch();
          } else {
            // 只有未展开且无内容时，才只打开搜索框
            openSearch();
          }
        });
      }

      // 输入框逻辑
      if (searchInput && !searchInput.dataset.bound) {
        searchInput.dataset.bound = 'true';
        // 阻止点击输入框时冒泡到 document 触发关闭
        searchInput.addEventListener('click', (e) => e.stopPropagation());

        // 监听回车键进行搜索
        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Enter') {
            performSearch();
          }
        });
      }

      // 点击空白区域关闭搜索
      if (!document.documentElement.dataset.searchClickBound) {
        document.documentElement.dataset.searchClickBound = 'true';
        document.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          // 如果点击的不是搜索容器内部，且搜索框已展开，则关闭
          if (searchContainer?.classList.contains('mdui-textfield-expanded') &&
              !searchContainer.contains(target)) {
            closeSearch();
          }
        });
      }

      // 初始化搜索框状态
      const urlParams = new URLSearchParams(window.location.search);
      const queryParam = urlParams.get('q');
      if (queryParam && searchInput && searchContainer) {
        searchInput.value = queryParam;
        searchContainer.classList.add('mdui-textfield-expanded');
      }

      // 初始化暗色模式状态
      const theme = localStorage.getItem('theme');
      const isDark = theme === 'dark' || !theme;
      if (isDark) {
        document.documentElement.classList.add('mdui-theme-layout-dark');
        if (darkModeIcon) darkModeIcon.innerText = 'brightness_4';
      } else {
        document.documentElement.classList.remove('mdui-theme-layout-dark');
        if (darkModeIcon) darkModeIcon.innerText = 'brightness_5';
      }
    } catch (err) {
      console.error('Header initialization failed:', err);
    }
  }

  // 使用 astro:page-load 处理初始加载和后续跳转
  document.addEventListener('astro:page-load', initHeader);

  // 全局 Escape 键监听，只绑定一次
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const searchContainer = document.getElementById('search-container');
    const drawer = document.getElementById('main-drawer');
    const overlay = document.getElementById('drawer-overlay');

    if (searchContainer?.classList.contains('mdui-textfield-expanded')) {
      searchContainer.classList.remove('mdui-textfield-expanded');
      return;
    }
    if (drawer?.classList.contains('mdui-drawer-open')) {
      drawer.classList.remove('mdui-drawer-open');
      overlay?.classList.remove('show');
      document.body.style.overflow = '';
    }
  });

  // 配合 Pace.js
  document.addEventListener('astro:before-preparation', () => {
    // @ts-ignore
    if (window.Pace) window.Pace.restart();
  });

  document.addEventListener('astro:page-load', () => {
    // @ts-ignore
    if (window.Pace) window.Pace.stop();
  });
</script>

{import.meta.env.PROD && <script is:inline>
