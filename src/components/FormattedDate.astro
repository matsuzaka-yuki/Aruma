---
import { siteConfig } from "../site.config";

interface Props {
	date: Date;
}

const { date } = Astro.props;
const locale = siteConfig.lang.startsWith("zh") ? "zh-CN" : "en-US";
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(locale, {
			year: "numeric",
			month: "short",
			day: "numeric",
		})
	}
</time>
