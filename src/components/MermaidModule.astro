---
// MermaidModule.astro
---

<script>
	// 在模块作用域内保持引用，避免页面切换导致重复监听
	let themeObserver: MutationObserver | null = null;

	async function initMermaid() {
		// 清理上一个 observer (Astro View Transitions 兼容)
		if (themeObserver) {
			themeObserver.disconnect();
			themeObserver = null;
		}

		// 选择由 Astro 默认渲染的 mermaid 代码块（未被隐藏处理过的内容）
		const rawBlocks = document.querySelectorAll(
			'pre[data-language="mermaid"], .mermaid'
		);
		
		// 过滤出真正的源块，避免选到已经被我们隐藏并生成过 Wrapper 的内容，但也需要支持重新渲染
		const blocks: HTMLElement[] = [];
		rawBlocks.forEach((b) => {
			const el = b as HTMLElement;
			// 如果是 wrapper 本身或者 wrapper 内部的，不作为源块
			if (!el.closest('.mermaid-wrapper') && el.tagName.toLowerCase() !== 'div') {
				blocks.push(el);
			}
		});

		if (blocks.length === 0) return;

		// 懒加载 mermaid 库
		const mermaidModule = await import("mermaid");
		const mermaid = mermaidModule.default;

		let currentTheme: "dark" | "default" = document.documentElement.classList.contains("mdui-theme-layout-dark") ? "dark" : "default";

		async function renderAll(theme: "dark" | "default") {
			mermaid.initialize({
				startOnLoad: false,
				theme: theme,
			});

			for (let i = 0; i < blocks.length; i++) {
				const block = blocks[i];
				
				// 记录原始文本，避免重复读取丢失
				if (!block.dataset.originalText) {
					const codeElement = block.querySelector("code");
					const text = codeElement ? codeElement.textContent : block.textContent;
					if (!text || text.trim() === "") continue;
					block.dataset.originalText = text;
				}

				const text = block.dataset.originalText;
				if (!text) continue;

				// 给原本的 pre 标签增加 class，防止被代码复制逻辑处理
				if (block.tagName.toLowerCase() === "pre") {
					block.classList.add("mermaid");
				}

				try {
					const id = `mermaid-svg-${Date.now()}-${i}`;
					const { svg } = await mermaid.render(id, text);
					
					// 查找是否已经存在 Wrapper（应该紧跟在 block 后面）
					let wrapper = block.nextElementSibling as HTMLElement;
					const hasWrapper = wrapper && wrapper.classList.contains("mermaid-wrapper");

					if (hasWrapper) {
						// 仅更新 SVG 视图内容，保留交互状态
						const content = wrapper.querySelector(".mermaid-content");
						if (content) {
							content.innerHTML = svg;
							const svgEl = content.querySelector("svg");
							if (svgEl) {
								svgEl.style.maxWidth = "100%";
								svgEl.style.height = "auto";
								svgEl.style.display = "block";
								svgEl.style.margin = "0 auto";
							}
						}
					} else {
						// 初次渲染：构建完整 UI 容器
						wrapper = document.createElement("div");
						wrapper.className = "mermaid-wrapper";

						const toolbar = document.createElement("div");
						toolbar.className = "mermaid-toolbar";
						toolbar.innerHTML = `
							<button class="mdui-btn mdui-btn-icon mdui-ripple btn-zoom-in" title="放大">
								<i class="mdui-icon material-icons">zoom_in</i>
							</button>
							<button class="mdui-btn mdui-btn-icon mdui-ripple btn-zoom-out" title="缩小">
								<i class="mdui-icon material-icons">zoom_out</i>
							</button>
							<button class="mdui-btn mdui-btn-icon mdui-ripple btn-reset" title="还原">
								<i class="mdui-icon material-icons">crop_free</i>
							</button>
						`;

						const viewport = document.createElement("div");
						viewport.className = "mermaid-viewport";

						const content = document.createElement("div");
						content.className = "mermaid-content";
						content.innerHTML = svg;
						
						const svgEl = content.querySelector("svg");
						if (svgEl) {
							svgEl.style.maxWidth = "100%";
							svgEl.style.height = "auto";
							svgEl.style.display = "block";
							svgEl.style.margin = "0 auto";
						}

						viewport.appendChild(content);
						wrapper.appendChild(toolbar);
						wrapper.appendChild(viewport);

						// 将 wrapper 插入到原有 block 之后
						block.parentNode?.insertBefore(wrapper, block.nextSibling);
						block.style.display = "none"; // 隐藏原本的 pre 源码块

						// ===== 拖拽与缩放交互逻辑 =====
						let scale = 1;
						let translateX = 0;
						let translateY = 0;
						let isDragging = false;
						let startX = 0;
						let startY = 0;

						const updateTransform = (smooth = false) => {
							content.style.transition = smooth ? "transform 0.2s cubic-bezier(0.4, 0, 0.2, 1)" : "none";
							content.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
						};

						// 1. 鼠标拖拽
						viewport.addEventListener("mousedown", (e) => {
							isDragging = true;
							startX = e.clientX - translateX;
							startY = e.clientY - translateY;
							viewport.style.cursor = "grabbing";
						});
						window.addEventListener("mousemove", (e) => {
							if (!isDragging) return;
							translateX = e.clientX - startX;
							translateY = e.clientY - startY;
							updateTransform(false);
						});
						window.addEventListener("mouseup", () => {
							if (isDragging) {
								isDragging = false;
								viewport.style.cursor = "grab";
							}
						});

						// 2. 鼠标滚轮缩放
						wrapper.addEventListener("wheel", (e) => {
							e.preventDefault(); 
							const zoomSensitivity = 0.002;
							const delta = -e.deltaY * zoomSensitivity;
							scale = Math.min(Math.max(0.3, scale + delta), 5);
							updateTransform(false);
						}, { passive: false });

						// 3. 移动端触摸处理
						let initialDistance = 0;
						let initialScale = 1;

						viewport.addEventListener("touchstart", (e) => {
							if (e.touches.length === 1) {
								isDragging = true;
								startX = e.touches[0].clientX - translateX;
								startY = e.touches[0].clientY - translateY;
							} else if (e.touches.length === 2) {
								isDragging = false;
								initialDistance = Math.hypot(
									e.touches[0].clientX - e.touches[1].clientX,
									e.touches[0].clientY - e.touches[1].clientY
								);
								initialScale = scale;
							}
						}, { passive: false });

						viewport.addEventListener("touchmove", (e) => {
							e.preventDefault();
							if (e.touches.length === 1 && isDragging) {
								translateX = e.touches[0].clientX - startX;
								translateY = e.touches[0].clientY - startY;
								updateTransform(false);
							} else if (e.touches.length === 2) {
								const distance = Math.hypot(
									e.touches[0].clientX - e.touches[1].clientX,
									e.touches[0].clientY - e.touches[1].clientY
								);
								const delta = (distance / initialDistance);
								scale = Math.min(Math.max(0.3, initialScale * delta), 5);
								updateTransform(false);
							}
						}, { passive: false });

						viewport.addEventListener("touchend", (e) => {
							if (e.touches.length < 2) {
								initialDistance = 0;
							}
							if (e.touches.length === 0) {
								isDragging = false;
							}
						});

						// 4. 按钮控制
						toolbar.querySelector('.btn-zoom-in')?.addEventListener('click', () => {
							scale = Math.min(scale * 1.25, 5);
							updateTransform(true);
						});
						toolbar.querySelector('.btn-zoom-out')?.addEventListener('click', () => {
							scale = Math.max(scale / 1.25, 0.3);
							updateTransform(true);
						});
						toolbar.querySelector('.btn-reset')?.addEventListener('click', () => {
							scale = 1;
							translateX = 0;
							translateY = 0;
							updateTransform(true);
						});
					}

				} catch (e) {
					console.error("Mermaid render error", e);
					block.style.display = "block"; // 失败时回退显示源码
				}
			}
		}

		// 首次渲染
		await renderAll(currentTheme);

		// 监听全局的主题变化，动态更新渲染图表的颜色
		themeObserver = new MutationObserver((mutations) => {
			for (const mutation of mutations) {
				if (mutation.attributeName === 'class') {
					const isDarkNow = document.documentElement.classList.contains("mdui-theme-layout-dark");
					const newTheme = isDarkNow ? "dark" : "default";
					if (newTheme !== currentTheme) {
						currentTheme = newTheme;
						// 重新生成 SVG 并替换内部内容
						renderAll(currentTheme);
					}
				}
			}
		});

		themeObserver.observe(document.documentElement, { attributes: true });
	}
	
	document.addEventListener("astro:page-load", initMermaid);
</script>

<style is:global>
	/* 外部包装器：匹配代码块卡片风格 */
	.mermaid-wrapper {
		position: relative;
		margin-bottom: 24px;
		background: #f9f9f9;
		border-radius: 5px;
		box-shadow: 0 10px 30px 0 rgb(0 0 0 / 10%);
		overflow: hidden;
		padding-top: 40px; /* 为顶部仿 macOS 按钮留出空间 */
		border: 1px solid var(--mdui-color-surface-variant, #e0e0e0);
		/* 添加过渡动画，切换黑暗模式时更平滑 */
		transition: background-color 0.3s ease, border-color 0.3s ease;
	}

	/* 适配暗色模式：匹配暗色代码块背景 */
	.mdui-theme-layout-dark .mermaid-wrapper {
		background: #21252b;
		box-shadow: 0 10px 30px 0 rgb(0 0 0 / 20%);
		border-color: #21252b;
	}

	/* 伪造 macOS 窗口红黄绿按钮 */
	.mermaid-wrapper::before {
		content: " ";
		position: absolute;
		top: 15px;
		left: 12px;
		width: 12px;
		height: 12px;
		border-radius: 50%;
		background: #fc625d;
		box-shadow:
			20px 0 #fdbc40,
			40px 0 #35cd4b;
		z-index: 2;
	}

	/* 视口：裁切溢出内容并响应操作 */
	.mermaid-viewport {
		width: 100%;
		min-height: 200px;
		max-height: 70vh;
		cursor: grab;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 1rem;
		box-sizing: border-box;
	}

	.mermaid-viewport:active {
		cursor: grabbing;
	}

	/* 内部画布：处理具体变换 */
	.mermaid-content {
		transform-origin: center center;
		will-change: transform;
		display: inline-block;
		transition: opacity 0.3s ease;
	}

	/* 浮动工具栏：横向排布并放在右上角 */
	.mermaid-toolbar {
		position: absolute;
		top: 8px;
		right: 10px;
		display: flex;
		flex-direction: row; /* 横向排布 */
		gap: 4px;
		z-index: 10;
		background: transparent;
	}

	/* 按钮视觉弱化 */
	.mermaid-toolbar .mdui-btn-icon {
		width: 28px;
		height: 28px;
		min-width: 28px;
		color: #888;
		transition: all 0.2s ease;
	}

	.mermaid-toolbar .mdui-btn-icon:hover {
		color: #333;
		background: rgba(0, 0, 0, 0.08);
	}

	.mdui-theme-layout-dark .mermaid-toolbar .mdui-btn-icon {
		color: #abb2bf;
	}

	.mdui-theme-layout-dark .mermaid-toolbar .mdui-btn-icon:hover {
		color: #fff;
		background: rgba(255, 255, 255, 0.1);
	}

	.mermaid-toolbar .material-icons {
		font-size: 18px;
	}
</style>
