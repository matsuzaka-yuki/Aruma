---
interface Props {
  columns?: 2 | 3 | 4;
  gap?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { columns = 2, gap = 'md', class: className = '' } = Astro.props;

const gridClasses = 'grid mt-5';
const columnClasses = {
  2: 'grid-cols-1 sm:grid-cols-2',
  3: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4',
};
const gapClasses = {
  sm: 'gap-3',
  md: 'gap-5',
  lg: 'gap-8',
};
---

<div class={`${gridClasses} ${columnClasses[columns]} ${gapClasses[gap]} ${className}`}>
  <slot />
</div>
