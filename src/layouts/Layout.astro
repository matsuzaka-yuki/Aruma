---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import PhotoSwipe from "../components/PhotoSwipe.astro";
import { siteConfig } from "../site.config";
import { ClientRouter } from "astro:transitions";
import "mdui/mdui.css";
import "../styles/material-icons.css";
import "mdui/components/dropdown.js";
import "mdui/components/icon.js";
import "../styles/aruma.css";
import "../styles/albums.css";

interface Props {
	title?: string;
	description?: string;
	hasMath?: boolean;
}

const {
	title = siteConfig.title,
	description = siteConfig.description,
	hasMath = false,
} = Astro.props;

let customFontFamily = "";
if (siteConfig.font) {
	const fonts: string[] = [];
	if (siteConfig.font.asciiFont?.fontFamily) {
		const asciiFont = siteConfig.font.asciiFont.fontFamily;
		fonts.push(asciiFont.includes(" ") ? `"${asciiFont}"` : asciiFont);
	}
	if (siteConfig.font.cjkFont?.fontFamily) {
		const cjkFont = siteConfig.font.cjkFont.fontFamily;
		fonts.push(cjkFont.includes(" ") ? `"${cjkFont}"` : cjkFont);
	}
	if (fonts.length > 0) {
		fonts.push(
			"system-ui",
			"-apple-system",
			"BlinkMacSystemFont",
			"'Segoe UI'",
			"Roboto",
			"sans-serif",
		);
		customFontFamily = fonts.join(", ");
	}
}
---

<!doctype html>
<html lang={siteConfig.lang}>
	<head>
		{/* 预加载首屏关键图片 */}
		<link
			rel="preload"
			as="image"
			href={siteConfig.background}
			fetchpriority="high"
		/>
		<link rel="preload" as="image" href={siteConfig.avatar} />
		<link rel="preload" as="image" href={siteConfig.sidebarBg} />
		{
			/* 阻塞式主题脚本 - 必须在任何样式加载之前执行，防止 FOUC (Flash of Unstyled Content) */
		}
		<script is:inline>
			(function () {
				const theme = localStorage.getItem("theme");
				// 默认暗色模式：theme === 'dark' 或 theme 为 null/undefined
				const isDark = theme === "dark" || theme === null;
				if (isDark) {
					document.documentElement.classList.add(
						"mdui-theme-layout-dark",
					);
				} else {
					document.documentElement.classList.remove(
						"mdui-theme-layout-dark",
					);
				}
			})();
		</script>
		<BaseHead title={title} description={description} hasMath={hasMath} />
		<ClientRouter />
		<script is:inline>
			window.paceOptions = {
				ajax: false, // 禁用 AJAX 监听，仅通过 Astro 钩子手动触发
				document: true,
				eventLag: false,
				restartOnPushState: false,
				restartOnRequestAfter: false,
			};
		</script>
		<script is:inline src="/pace.min.js" defer></script>
		<style
			define:vars={{
				backgroundImage: `url(${siteConfig.background})`,
				"custom-font-family": customFontFamily,
			}}
		>
			:root {
				--background-image: var(--backgroundImage);
			}
			body {
				font-family: var(
					--custom-font-family,
					Roboto,
					Noto,
					Helvetica,
					Arial,
					sans-serif
				);
				margin: 0;
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}
			.main-container {
				max-width: 1150px;
				margin: 0 auto;
				padding: 32px 16px 0; /* 减小上边距使内容上移 */
				width: 100%;
				box-sizing: border-box;
				display: flex;
				gap: 0;
				flex: 1; /* 撑开容器，将 footer 推到底部 */
			}
			.background {
				background-image: var(--background-image);
			}
			.content-area {
				flex: 1;
				min-width: 0;
				padding: 12px 0; /* 减小上下间距 */
			}
			.sidebar-area {
				width: 33.33333333%;
				flex-shrink: 0;
				padding: 12px 0 20px 35px; /* 同步减小顶部间距 */
			}
			@media (max-width: 1024px) {
				.main-container {
					flex-direction: column;
					padding: 56px 10px 0; /* 适配移动端导航栏高度，对齐顶栏 */
				}
				.content-area {
					padding: 10px 0;
				}
				.sidebar-area {
					width: 100%;
					padding: 10px 0; /* 移动端移除左侧 35px 偏移，防止右偏 */
				}
			}
		</style>
		<script is:inline>
			const getTheme = () => {
				const theme = localStorage.getItem("theme");
				return theme === "dark" || !theme;
			};

			const setTheme = () => {
				if (getTheme()) {
					document.documentElement.classList.add(
						"mdui-theme-layout-dark",
					);
				} else {
					document.documentElement.classList.remove(
						"mdui-theme-layout-dark",
					);
				}
			};

			// Initial setup
			setTheme();

			// Re-apply theme before View Transitions navigation to prevent FOUC
			document.addEventListener("astro:before-swap", (event) => {
				if (getTheme()) {
					event.newDocument.documentElement.classList.add(
						"mdui-theme-layout-dark",
					);
				} else {
					event.newDocument.documentElement.classList.remove(
						"mdui-theme-layout-dark",
					);
				}
			});
		</script>
	</head>
	<body class="mdui-theme-primary-pink mdui-theme-accent-pink">
		<div class="background"><div class="index-filter"></div></div>
		<Header />
		<div class="main-container">
			<main class="content-area page-transition">
				<slot />
			</main>
			<aside class="sidebar-area">
				<slot name="sidebar" />
			</aside>
		</div>
		<Footer />
		<PhotoSwipe />
		<script>
			import "mdui/components/dropdown.js";
			import "mdui/components/icon.js";

			// KaTeX CSS 懒加载 - 只有当页面包含数学公式时才加载样式
			function loadKatexCSS() {
				if (document.querySelector(".katex")) {
					import("katex/dist/katex.css");
				}
			}

			// 页面加载时检查
			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", loadKatexCSS);
			} else {
				loadKatexCSS();
			}

			// Astro View Transitions 页面切换后重新检查
			document.addEventListener("astro:page-load", loadKatexCSS);
		</script>
	</body>
</html>
