---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../site.config';
// @ts-ignore - ViewTransitions deprecated but still required for page transitions
import { ViewTransitions } from 'astro:transitions';
import 'mdui/mdui.css';
import '../styles/material-icons.css';
import 'mdui';
import '../styles/aruma.css';
import '../styles/albums.css';

interface Props {
	title?: string;
	description?: string;
}

const { title = siteConfig.title, description = siteConfig.description } = Astro.props;
---

<!doctype html>
<html lang={siteConfig.lang}>
	<head>
		{/* 阻塞式主题脚本 - 必须在任何样式加载之前执行，防止 FOUC (Flash of Unstyled Content) */}
		<script is:inline>
			(function() {
				const theme = localStorage.getItem('theme');
				// 默认暗色模式：theme === 'dark' 或 theme 为 null/undefined
				const isDark = theme === 'dark' || theme === null;
				if (isDark) {
					document.documentElement.classList.add('mdui-theme-layout-dark');
				} else {
					document.documentElement.classList.remove('mdui-theme-layout-dark');
				}
			})();
		</script>
		<BaseHead title={title} description={description} />
		<ViewTransitions />
		<script is:inline>
			window.paceOptions = {
				ajax: false, // 禁用 AJAX 监听，仅通过 Astro 钩子手动触发
				document: true,
				eventLag: false,
				restartOnPushState: false,
				restartOnRequestAfter: false
			};
		</script>
		<script is:inline src="/pace.min.js"></script>
		<style define:vars={{ backgroundImage: `url(${siteConfig.background})` }}>
			:root {
				--background-image: var(--backgroundImage);
			}
			body {
				font-family: Roboto, Noto, Helvetica, Arial, sans-serif;
				margin: 0;
				display: flex;
				flex-direction: column;
				min-height: 100vh;
			}
			.main-container {
				max-width: 1150px;
				margin: 0 auto;
				padding: 32px 16px 0; /* 减小上边距使内容上移 */
				width: 100%;
				box-sizing: border-box;
				display: flex;
				gap: 0;
				flex: 1; /* 撑开容器，将 footer 推到底部 */
			}
			.background {
				background-image: var(--background-image);
			}
			.content-area {
				flex: 1;
				min-width: 0;
				padding: 12px 0; /* 减小上下间距 */
			}
			.sidebar-area {
				width: 33.33333333%;
				flex-shrink: 0;
				padding: 12px 0 20px 35px; /* 同步减小顶部间距 */
			}
			@media (max-width: 1024px) {
				.main-container {
					flex-direction: column;
					padding: 56px 10px 0; /* 适配移动端导航栏高度，对齐顶栏 */
				}
				.content-area {
					padding: 10px 0;
				}
				.sidebar-area {
					width: 100%;
					padding: 10px 0; /* 移动端移除左侧 35px 偏移，防止右偏 */
				}
			}
		</style>
		<script is:inline>
			const getTheme = () => {
				const theme = localStorage.getItem('theme');
				return theme === 'dark' || !theme;
			};

			const setTheme = () => {
				if (getTheme()) {
					document.documentElement.classList.add('mdui-theme-layout-dark');
				} else {
					document.documentElement.classList.remove('mdui-theme-layout-dark');
				}
			};

		// Initial setup
		setTheme();

		// Re-apply theme before View Transitions navigation to prevent FOUC
		document.addEventListener('astro:before-swap', (event) => {
			if (getTheme()) {
				event.newDocument.documentElement.classList.add('mdui-theme-layout-dark');
			} else {
				event.newDocument.documentElement.classList.remove('mdui-theme-layout-dark');
			}
		});
		</script>
	</head>
	<body class="mdui-theme-primary-pink mdui-theme-accent-pink">
		<div class="background"><div class="index-filter"></div></div>
		<Header />
		<div class="main-container">
			<main class="content-area">
				<slot />
			</main>
			<aside class="sidebar-area">
				<slot name="sidebar" />
			</aside>
		</div>
		<Footer />
		<script>
			import 'mdui';
		</script>
	</body>
</html>
