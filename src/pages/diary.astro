---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import PhotoSwipe from "../components/PhotoSwipe.astro";
import diaryData from "../data/diary.json";
import { i18n } from "../i18n/translation";
import I18nKey from "../i18n/i18nKey";

interface DiaryItem {
	id: number;
	content: string;
	date: string;
	images?: string[];
	tags?: string[];
}

const diaries = (diaryData as DiaryItem[]).sort(
	(a, b) => new Date(b.date).getTime() - new Date(a.date).getTime(),
);

function formatTime(dateString: string): string {
	const now = new Date();
	const date = new Date(dateString);
	const diffInMinutes = Math.floor(
		(now.getTime() - date.getTime()) / (1000 * 60),
	);

	if (diffInMinutes < 60) {
		return `${diffInMinutes}${i18n(I18nKey.diaryMinutesAgo)}`;
	}
	if (diffInMinutes < 1440) {
		const hours = Math.floor(diffInMinutes / 60);
		return `${hours}${i18n(I18nKey.diaryHoursAgo)}`;
	}
	const days = Math.floor(diffInMinutes / 1440);
	return `${days}${i18n(I18nKey.diaryDaysAgo)}`;
}
---

<Layout title={i18n(I18nKey.diaryTitle)}>
	<div class="article">
		<div class="diary-container">
			{
				diaries.map((item) => (
					<div class="mdui-card diary-card mdui-hoverable">
						<div class="diary-header">
							<div class="diary-time">
								<i class="mdui-icon material-icons">
									access_time
								</i>
								<time datetime={item.date}>
									{formatTime(item.date)}
								</time>
							</div>
							{item.tags && item.tags.length > 0 && (
								<div class="diary-tags">
									{item.tags.map((tag) => (
										<span class="diary-tag">#{tag}</span>
									))}
								</div>
							)}
						</div>

						<div class="diary-content mdui-typo">
							{item.content}
						</div>

						{item.images && item.images.length > 0 && (
							<div class="diary-images grid">
								{item.images.map((image) => (
									<div class="image-item">
										<img
											src={image}
											alt="diary image"
											loading="lazy"
										/>
									</div>
								))}
							</div>
						)}
					</div>
				))
			}
		</div>
	</div>

	<PhotoSwipe />
	<Sidebar slot="sidebar" />
</Layout>

<style>
	.diary-container {
		display: flex;
		flex-direction: column;
		gap: 20px;
		margin-top: 20px;
	}

	.diary-card {
		padding: 16px 20px;
		background-color: rgba(255, 255, 255, 0.8);
		border-radius: 7px;
		transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
	}

	.diary-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 12px;
	}

	.diary-time {
		display: flex;
		align-items: center;
		gap: 6px;
		font-size: 13px;
		color: rgba(var(--gray), 0.7);
	}

	.diary-time i {
		font-size: 16px;
	}

	.diary-tags {
		display: flex;
		gap: 8px;
	}

	.diary-tag {
		font-size: 12px;
		color: var(--color);
		opacity: 0.8;
	}

	.diary-content {
		font-size: 16px;
		line-height: 1.6;
		margin-bottom: 12px;
		white-space: pre-wrap;
		word-break: break-all;
	}

	.diary-images {
		margin-top: 12px;
		border-radius: 8px;
		overflow: hidden;
	}

	.diary-images.grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
		gap: 8px;
	}

	.image-item {
		aspect-ratio: 1;
		overflow: hidden;
		border-radius: 4px;
	}

	.image-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.3s;
	}

	.image-item img:hover {
		transform: scale(1.05);
	}

	/* 暗色模式适配 */
	:global(.mdui-theme-layout-dark) .diary-card {
		background-color: rgba(66, 66, 66, 0.8);
	}

	:global(.mdui-theme-layout-dark) .diary-content {
		color: rgba(255, 255, 255, 0.9);
	}

	:global(.mdui-theme-layout-dark) .diary-time {
		color: rgba(255, 255, 255, 0.6);
	}

	@media (max-width: 600px) {
		.diary-card {
			padding: 16px;
		}
		.diary-images.grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
</style>
