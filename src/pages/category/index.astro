---
import Layout from '../../layouts/Layout.astro';
import Sidebar from '../../components/Sidebar.astro';
import { getCollection } from 'astro:content';
import { i18n } from '../../i18n/translation';
import I18nKey from '../../i18n/i18nKey';

const posts = await getCollection('post');
const categoryCounts = posts.reduce((acc, post) => {
  const category = post.data.category?.trim();
  if (!category) return acc;
  acc[category] = (acc[category] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const categories = Object.entries(categoryCounts)
  .map(([name, count]) => ({
    name,
    count,
    slug: encodeURIComponent(name)
  }))
  .sort((a, b) => b.count - a.count || a.name.localeCompare(b.name, 'zh'));
---

<Layout title={i18n(I18nKey.categoryTitle)}>
  <div class="article">
    <div class="mdui-card archive-card mdui-hoverable">
      <div class="archive-title">
        <span>{i18n(I18nKey.categoryTitle)}</span>
      </div>
    </div>

    <div class="category-container">
      {categories.map(category => (
        <a href={`/category/${category.slug}`} class="category-card mdui-card mdui-hoverable">
          <span class="category-name">{category.name}</span>
          <span class="category-count">{category.count}</span>
        </a>
      ))}
    </div>
  </div>

  <Sidebar slot="sidebar" />
</Layout>

<style>
  .category-container {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    margin-top: 20px;
  }
  .category-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    background-color: rgba(255, 255, 255, 0.8);
    border-radius: 7px;
    color: #333;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  }
  .category-name {
    font-size: 16px;
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .category-count {
    background: rgba(0, 0, 0, 0.08);
    color: #333;
    font-size: 12px;
    padding: 2px 8px;
    border-radius: 12px;
  }
  :global(.mdui-theme-layout-dark) .category-card {
    background-color: rgba(66, 66, 66, 0.8);
    color: rgba(255, 255, 255, 0.9);
  }
  :global(.mdui-theme-layout-dark) .category-count {
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.8);
  }
  @media (max-width: 768px) {
    .category-container {
      grid-template-columns: 1fr;
    }
  }
</style>
