---
import { existsSync, readFileSync } from "fs";
import { join } from "path";

import AnimeCard from "../components/cards/AnimeCard.astro";
import FilterModule from "../components/FilterModule.astro";
import Sidebar from "../components/Sidebar.astro";
import localAnimeData from "../data/anime.json";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../site.config";
import type { AnimeItem } from "../types/anime";
import { getAnimeStatus } from "../utils/anime-utils";

// 动漫过滤选项配置
const animeFilters = [
	{ value: "all", label: i18n(I18nKey.all) },
	{ value: "watching", label: i18n(I18nKey.watching) },
	{ value: "completed", label: i18n(I18nKey.completed) },
	{ value: "planned", label: i18n(I18nKey.planned) },
	...(siteConfig.animeSource?.mode === "bangumi"
		? [
				{ value: "onhold", label: i18n(I18nKey.animeStatusOnHold) },
				{ value: "dropped", label: i18n(I18nKey.animeStatusDropped) },
			]
		: []),
];

/**
 * 获取外部动漫数据
 * 从 src/data/external-anime.json 读取缓存的数据
 */
function getExternalAnimeData(): {
	bilibili: AnimeItem[];
	bangumi: AnimeItem[];
} {
	// 检查 animeSource 配置是否启用
	if (!siteConfig.animeSource?.enable) {
		return { bilibili: [], bangumi: [] };
	}

	// 使用绝对路径读取外部数据
	// 在 Astro 构建时，使用 process.cwd() 获取项目根目录
	const projectRoot = process.cwd();
	const externalDataPath = join(projectRoot, "src/data/external-anime.json");

	try {
		if (!existsSync(externalDataPath)) {
			console.log(
				"External anime data file not found at:",
				externalDataPath,
			);
			return { bilibili: [], bangumi: [] };
		}

		const externalData = JSON.parse(
			readFileSync(externalDataPath, "utf-8"),
		);

		return {
			bilibili: externalData?.bilibili || [],
			bangumi: externalData?.bangumi || [],
		};
	} catch (error) {
		console.log("External anime data not available:", error);
		return { bilibili: [], bangumi: [] };
	}
}

/**
 * 合并和排序动漫数据
 * 根据配置决定使用哪些数据源
 */
function mergeAnimeData(
	local: AnimeItem[],
	external: { bilibili: AnimeItem[]; bangumi: AnimeItem[] },
	config = siteConfig.animeSource,
): AnimeItem[] {
	if (!config?.enable) {
		// 如果未启用外部数据源，只返回本地数据
		return local as AnimeItem[];
	}

	let result: AnimeItem[] = [];

	// 根据 mode 决定使用哪些数据源
	switch (config.mode) {
		case "local":
			result = [...local] as AnimeItem[];
			break;
		case "bilibili":
			result = [...external.bilibili];
			break;
		case "bangumi":
			result = [...external.bangumi];
			break;
		case "mixed":
		default:
			// 混合模式：合并所有数据源
			result = [
				...(local as AnimeItem[]),
				...external.bilibili,
				...external.bangumi,
			];
			break;
	}

	// 按年份排序（新的在前）
	result.sort((a, b) => {
		const yearA = parseInt(a.year) || 0;
		const yearB = parseInt(b.year) || 0;
		return yearB - yearA;
	});

	return result;
}

// 获取数据
const externalData = getExternalAnimeData();
const allAnime = mergeAnimeData(localAnimeData, externalData);
---

<Layout title={i18n(I18nKey.animeTitle)}>
	<div class="article anime-container-layout">
		<div class="mdui-card archive-card mdui-hoverable">
			<div class="archive-title">
				<span>{i18n(I18nKey.animeTitle)}</span>
			</div>
		</div>

		<main
			class="anime-page"
			data-page-size={siteConfig.animeSource?.pageSize || 0}
		>
			<!-- 过滤和搜索 -->
			<FilterModule
				filters={animeFilters}
				searchPlaceholder={i18n(I18nKey.searchAnime)}
				searchId="anime-search"
				cardSelector=".anime-card"
				searchableFields={[".anime-name", ".anime-description"]}
				filterAttribute="data-status"
			/>

			<!-- 番剧列表 -->
			<div id="anime-list-container" class="anime-list-container">
				{
					allAnime.length === 0 ? (
						<div class="anime-empty">
							<mdui-icon
								name="sentiment_dissatisfied"
								class="anime-empty-icon"
							/>
							<h3>{i18n(I18nKey.animeEmpty)}</h3>
						</div>
					) : (
						allAnime.map((anime) => (
							<AnimeCard
								title={anime.title}
								cover={anime.cover}
								link={anime.link}
								description={anime.description}
								year={anime.year}
								studio={anime.studio}
								progress={anime.progress}
								totalEpisodes={anime.totalEpisodes}
								status={getAnimeStatus(anime)}
							/>
						))
					)
				}
			</div>

			<!-- 分页控件 -->
			{
				siteConfig.animeSource?.pageSize &&
					allAnime.length > siteConfig.animeSource.pageSize && (
						<div class="anime-pagination" id="anime-pagination">
							<button
								class="pagination-btn prev-page"
								id="prev-page"
								disabled
							>
								<mdui-icon name="chevron_left" />
								<span>{i18n(I18nKey.prevPage)}</span>
							</button>
							<div class="pagination-info">
								<span id="current-page">1</span> /{" "}
								<span id="total-pages">1</span>
							</div>
							<button
								class="pagination-btn next-page"
								id="next-page"
							>
								<span>{i18n(I18nKey.nextPage)}</span>
								<mdui-icon name="chevron_right" />
							</button>
						</div>
					)
			}
		</main>
	</div>

	<Sidebar slot="sidebar" />
</Layout>

<style>
	.anime-container-layout {
		display: flex;
		flex-direction: column;
	}

	.anime-page {
		margin-top: 20px;
		padding: 0;
		flex: 1;
	}

	.anime-list-container {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.25rem;
		align-content: start;
	}

	@media (min-width: 1024px) {
		.anime-list-container {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.anime-card {
		content-visibility: auto;
		contain-intrinsic-size: 1px 200px;
		transition:
			opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1),
			transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.anime-card.anime-fade-out {
		opacity: 0;
		transform: scale(0.95);
		pointer-events: none;
	}

	.anime-card.anime-fade-in {
		opacity: 0;
		transform: scale(0.95);
	}

	.anime-card.anime-fade-in-active {
		opacity: 1;
		transform: scale(1);
	}

	.anime-card.anime-hidden {
		display: none !important;
	}

	@media (max-width: 768px) {
		.anime-card {
			-webkit-transform: translateZ(0);
			transform: translateZ(0);
			-webkit-backface-visibility: hidden;
			backface-visibility: hidden;
		}
	}

	.anime-empty {
		text-align: center;
		padding: 60px 20px;
	}

	.anime-empty-icon {
		font-size: 64px;
		color: var(--mdui-color-on-surface-variant, #bdbdbd);
		margin-bottom: 16px;
	}

	.anime-empty h3 {
		font-size: 18px;
		font-weight: 500;
		color: var(--mdui-color-on-surface-variant, #9e9e9e);
		margin: 0;
	}

	.anime-pagination {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 1.5rem;
		margin-top: 2rem;
		margin-bottom: 2rem;
	}

	.pagination-btn {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.5rem 1rem;
		border: 1px solid var(--mdui-color-outline, #e0e0e0);
		border-radius: 8px;
		background: var(--archive-card-bg);
		color: var(--mdui-color-on-surface, #212121);
		cursor: pointer;
		transition: all 0.2s;
		font-weight: 500;
	}

	.pagination-btn:hover:not(:disabled) {
		background: var(--mdui-color-surface-container, #f5f5f5);
		border-color: var(--color, #ff4081);
		color: var(--color, #ff4081);
	}

	.pagination-btn:disabled {
		opacity: 0.5;
		cursor: not-allowed;
	}

	.pagination-info {
		font-weight: 600;
		color: var(--mdui-color-on-surface, #212121);
	}

	:global(.mdui-theme-layout-dark) .pagination-btn {
		background: var(--archive-card-bg);
		color: rgba(255, 255, 255, 0.9);
		border-color: rgba(255, 255, 255, 0.3);
	}

	:global(.mdui-theme-layout-dark) .pagination-info {
		color: rgba(255, 255, 255, 0.9);
	}

	@media (prefers-reduced-motion: reduce) {
		.anime-card {
			transition-duration: 0.15s;
		}
	}
</style>

<script>
	// 客户端交互逻辑 - 与 FilterModule 配合使用
	document.addEventListener("astro:page-load", () => {
		const animePage = document.querySelector(
			".anime-page",
		) as HTMLElement | null;
		const paginationContainer = document.getElementById("anime-pagination");
		const prevPageBtn = document.getElementById(
			"prev-page",
		) as HTMLButtonElement | null;
		const nextPageBtn = document.getElementById(
			"next-page",
		) as HTMLButtonElement | null;
		const currentPageSpan = document.getElementById("current-page");
		const totalPagesSpan = document.getElementById("total-pages");

		const pageSize = parseInt(animePage?.dataset.pageSize || "0");
		let currentPage = 1;

		// 初始分页
		if (pageSize > 0) {
			applyPagination();
		}

		// 监听 FilterModule 的过滤变化事件
		window.addEventListener("filter-changed", () => {
			currentPage = 1; // 重置页码
			applyPagination();
		});

		// 分页按钮点击事件
		prevPageBtn?.addEventListener("click", () => {
			if (currentPage > 1) {
				currentPage--;
				applyPagination();
			}
		});

		nextPageBtn?.addEventListener("click", () => {
			const totalPages = parseInt(totalPagesSpan?.textContent || "1");
			if (currentPage < totalPages) {
				currentPage++;
				applyPagination();
			}
		});

		function applyPagination() {
			// 获取所有动漫卡片
			const allCards = document.querySelectorAll(".anime-card");
			// 获取当前可见的卡片（没有被 FilterModule 隐藏的）
			const visibleCards = Array.from(allCards).filter(
				(card) => !card.classList.contains("item-hidden"),
			);

			const totalItems = visibleCards.length;
			const totalPages = Math.max(1, Math.ceil(totalItems / pageSize));

			if (currentPage > totalPages) {
				currentPage = totalPages;
			}
			if (currentPage < 1) {
				currentPage = 1;
			}

			// 更新分页 UI
			if (paginationContainer) {
				if (pageSize > 0 && totalItems > pageSize) {
					paginationContainer.style.display = "flex";
					if (currentPageSpan) {
						currentPageSpan.textContent = currentPage.toString();
					}
					if (totalPagesSpan) {
						totalPagesSpan.textContent = totalPages.toString();
					}
					if (prevPageBtn) {
						prevPageBtn.disabled = currentPage === 1;
					}
					if (nextPageBtn) {
						nextPageBtn.disabled = currentPage === totalPages;
					}
				} else {
					paginationContainer.style.display = "none";
				}
			}

			// 计算当前页的卡片范围
			const startIndex = (currentPage - 1) * pageSize;
			const endIndex = startIndex + pageSize;

			// 显示/隐藏卡片
			visibleCards.forEach((card, index) => {
				const cardElement = card as HTMLElement;
				if (pageSize > 0) {
					// 分页模式
					if (index >= startIndex && index < endIndex) {
						cardElement.style.display = "";
						cardElement.classList.remove("anime-hidden");
					} else {
						cardElement.style.display = "none";
						cardElement.classList.add("anime-hidden");
					}
				} else {
					// 非分页模式 - 保持 FilterModule 的显示状态
					if (cardElement.classList.contains("item-hidden")) {
						cardElement.style.display = "none";
						cardElement.classList.add("anime-hidden");
					} else {
						cardElement.style.display = "";
						cardElement.classList.remove("anime-hidden");
					}
				}
			});
		}
	});
</script>
