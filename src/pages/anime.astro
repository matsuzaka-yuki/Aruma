---
import { existsSync, readFileSync } from "fs";
import { join } from "path";

import AnimeCard from "../components/cards/AnimeCard.astro";
import FilterModule from "../components/FilterModule.astro";
import Sidebar from "../components/Sidebar.astro";
import Pagination from "../components/ui/Pagination.astro";
import localAnimeData from "../data/anime.json";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../site.config";
import type { AnimeItem } from "../types/anime";
import { getAnimeStatus } from "../utils/anime-utils";

// 动漫过滤选项配置
const animeFilters = [
	{ value: "all", label: i18n(I18nKey.all) },
	{ value: "watching", label: i18n(I18nKey.watching) },
	{ value: "completed", label: i18n(I18nKey.completed) },
	{ value: "planned", label: i18n(I18nKey.planned) },
	...(siteConfig.animeSource?.mode === "bangumi"
		? [
				{ value: "onhold", label: i18n(I18nKey.animeStatusOnHold) },
				{ value: "dropped", label: i18n(I18nKey.animeStatusDropped) },
			]
		: []),
];

/**
 * 获取外部动漫数据
 * 从 src/data/external-anime.json 读取缓存的数据
 */
function getExternalAnimeData(): {
	bilibili: AnimeItem[];
	bangumi: AnimeItem[];
} {
	// 检查 animeSource 配置是否启用
	if (!siteConfig.animeSource?.enable) {
		return { bilibili: [], bangumi: [] };
	}

	// 使用绝对路径读取外部数据
	// 在 Astro 构建时，使用 process.cwd() 获取项目根目录
	const projectRoot = process.cwd();
	const externalDataPath = join(projectRoot, "src/data/external-anime.json");

	try {
		if (!existsSync(externalDataPath)) {
			console.log(
				"External anime data file not found at:",
				externalDataPath,
			);
			return { bilibili: [], bangumi: [] };
		}

		const externalData = JSON.parse(
			readFileSync(externalDataPath, "utf-8"),
		);

		return {
			bilibili: externalData?.bilibili || [],
			bangumi: externalData?.bangumi || [],
		};
	} catch (error) {
		console.log("External anime data not available:", error);
		return { bilibili: [], bangumi: [] };
	}
}

/**
 * 合并和排序动漫数据
 * 根据配置决定使用哪些数据源
 */
function mergeAnimeData(
	local: AnimeItem[],
	external: { bilibili: AnimeItem[]; bangumi: AnimeItem[] },
	config = siteConfig.animeSource,
): AnimeItem[] {
	if (!config?.enable) {
		// 如果未启用外部数据源，只返回本地数据
		return local as AnimeItem[];
	}

	let result: AnimeItem[] = [];

	// 根据 mode 决定使用哪些数据源
	switch (config.mode) {
		case "local":
			result = [...local] as AnimeItem[];
			break;
		case "bilibili":
			result = [...external.bilibili];
			break;
		case "bangumi":
			result = [...external.bangumi];
			break;
		case "mixed":
		default:
			// 混合模式：合并所有数据源
			result = [
				...(local as AnimeItem[]),
				...external.bilibili,
				...external.bangumi,
			];
			break;
	}

	// 按年份排序（新的在前）
	result.sort((a, b) => {
		const yearA = parseInt(a.year) || 0;
		const yearB = parseInt(b.year) || 0;
		return yearB - yearA;
	});

	return result;
}

// 获取数据
const externalData = getExternalAnimeData();
const allAnime = mergeAnimeData(localAnimeData, externalData);
---

<Layout title={i18n(I18nKey.animeTitle)}>
	<div class="article anime-container-layout">
		<div class="mdui-card archive-card mdui-hoverable">
			<div class="archive-title">
				<span>{i18n(I18nKey.animeTitle)}</span>
			</div>
		</div>

		<main class="anime-page">
			<!-- 过滤和搜索 -->
			<FilterModule
				filters={animeFilters}
				searchPlaceholder={i18n(I18nKey.searchAnime)}
				searchId="anime-search"
				cardSelector=".anime-card"
				searchableFields={[".anime-name", ".anime-description"]}
				filterAttribute="data-status"
			/>

			<!-- 番剧列表 -->
			<div id="anime-container" class="anime-container anime-mode">
				{
					allAnime.length === 0 ? (
						<div class="anime-empty">
							<mdui-icon
								name="sentiment_dissatisfied"
								class="anime-empty-icon"
							/>
							<h3>{i18n(I18nKey.animeEmpty)}</h3>
						</div>
					) : (
						allAnime.map((anime) => (
							<AnimeCard
								title={anime.title}
								cover={anime.cover}
								link={anime.link}
								description={anime.description}
								year={anime.year}
								studio={anime.studio}
								progress={anime.progress}
								totalEpisodes={anime.totalEpisodes}
								status={getAnimeStatus(anime)}
							/>
						))
					)
				}
			</div>

			<!-- 分页控件 -->
			{
				siteConfig.animeSource?.pageSize &&
					allAnime.length > siteConfig.animeSource.pageSize && (
						<Pagination
							id="anime-pagination"
							pageSize={siteConfig.animeSource.pageSize}
							totalItems={allAnime.length}
							itemSelector=".anime-card"
							hiddenClass="anime-hidden"
						/>
					)
			}
		</main>
	</div>

	<Sidebar slot="sidebar" />
</Layout>

<style>
	.anime-container-layout {
		display: flex;
		flex-direction: column;
	}

	.anime-page {
		margin-top: 20px;
		padding: 0;
		flex: 1;
	}

	.anime-container {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.25rem;
		align-content: start;
	}

	@media (min-width: 1024px) {
		.anime-container {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.anime-card {
		content-visibility: auto;
		contain-intrinsic-size: 1px 200px;
		transition:
			opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1),
			transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.anime-card.anime-fade-out {
		opacity: 0;
		transform: scale(0.95);
		pointer-events: none;
	}

	.anime-card.anime-fade-in {
		opacity: 0;
		transform: scale(0.95);
	}

	.anime-card.anime-fade-in-active {
		opacity: 1;
		transform: scale(1);
	}

	.anime-card.anime-hidden {
		display: none !important;
	}

	@media (max-width: 768px) {
		.anime-card {
			-webkit-transform: translateZ(0);
			transform: translateZ(0);
			-webkit-backface-visibility: hidden;
			backface-visibility: hidden;
		}
	}

	.anime-empty {
		text-align: center;
		padding: 60px 20px;
	}

	.anime-empty-icon {
		font-size: 64px;
		color: var(--mdui-color-on-surface-variant, #bdbdbd);
		margin-bottom: 16px;
	}

	.anime-empty h3 {
		font-size: 18px;
		font-weight: 500;
		color: var(--mdui-color-on-surface-variant, #9e9e9e);
		margin: 0;
	}

	@media (prefers-reduced-motion: reduce) {
		.anime-card {
			transition-duration: 0.15s;
		}
	}

	.anime-container.anime-mode {
		grid-template-columns: 1fr;
	}

	@media (min-width: 1280px) {
		.anime-container.anime-mode {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.anime-container.anime-mode .anime-card {
		display: flex;
		flex-direction: row;
		min-height: 12rem;
	}

	.anime-container.anime-mode .anime-cover {
		width: 8.5rem;
		aspect-ratio: 2/3;
		flex-shrink: 0;
	}

	@media (min-width: 768px) {
		.anime-container.anime-mode .anime-cover {
			width: 11rem;
		}
	}

	.anime-container.anime-mode .anime-content {
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		padding: 0.75rem 1rem;
		min-width: 0;
		min-height: 160px;
	}
</style>
