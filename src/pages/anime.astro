---
import { existsSync, readFileSync } from "fs";
import { join } from "path";

import AnimeCard from "../components/cards/AnimeCard.astro";
import FilterModule from "../components/FilterModule.astro";
import FlipAnimationModule from "../components/FlipAnimationModule.astro";
import Sidebar from "../components/Sidebar.astro";
import Pagination from "../components/ui/Pagination.astro";
// 导入本地动漫数据
import localAnimeData from "../data/anime.json";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../site.config";
import type { AnimeItem } from "../types/anime";

function getExternalAnimeData(): {
	bilibili: AnimeItem[];
	bangumi: AnimeItem[];
} {
	if (!siteConfig.animeSource?.enable) {
		return { bilibili: [], bangumi: [] };
	}

	const projectRoot = process.cwd();
	const externalDataPath = join(projectRoot, "src/data/external-anime.json");

	try {
		if (!existsSync(externalDataPath)) {
			console.log(
				"External anime data file not found at:",
				externalDataPath,
			);
			return { bilibili: [], bangumi: [] };
		}

		const externalData = JSON.parse(
			readFileSync(externalDataPath, "utf-8"),
		);

		return {
			bilibili: externalData?.bilibili || [],
			bangumi: externalData?.bangumi || [],
		};
	} catch (error) {
		console.log("External anime data not available:", error);
		return { bilibili: [], bangumi: [] };
	}
}

function mergeAnimeData(
	local: AnimeItem[],
	external: { bilibili: AnimeItem[]; bangumi: AnimeItem[] },
	config = siteConfig.animeSource,
): AnimeItem[] {
	if (!config?.enable) {
		return local as AnimeItem[];
	}

	let result: AnimeItem[] = [];

	switch (config.mode) {
		case "local":
			result = [...local] as AnimeItem[];
			break;
		case "bilibili":
			result = [...external.bilibili];
			break;
		case "bangumi":
			result = [...external.bangumi];
			break;
		case "mixed":
		default:
			result = [
				...(local as AnimeItem[]),
				...external.bilibili,
				...external.bangumi,
			];
			break;
	}

	result.sort((a, b) => {
		const yearA = parseInt(a.year) || 0;
		const yearB = parseInt(b.year) || 0;
		return yearB - yearA;
	});

	return result;
}

const externalData = getExternalAnimeData();
const allAnime = mergeAnimeData(localAnimeData, externalData);

const animeFilters = [
	{ value: "all", label: i18n(I18nKey.all) },
	{ value: "watching", label: i18n(I18nKey.watching) },
	{ value: "completed", label: i18n(I18nKey.completed) },
	{ value: "planned", label: i18n(I18nKey.planned) },
];

if (siteConfig.animeSource?.mode === "bangumi") {
	animeFilters.push({
		value: "onhold",
		label: i18n(I18nKey.animeStatusOnHold),
	});
	animeFilters.push({
		value: "dropped",
		label: i18n(I18nKey.animeStatusDropped),
	});
}
---

<Layout title={i18n(I18nKey.animeTitle)}>
	<div class="article anime-container-layout">
		<div class="mdui-card archive-card mdui-hoverable">
			<div class="archive-title">
				<span>{i18n(I18nKey.animeTitle)}</span>
			</div>
		</div>

		<main
			class="anime-page"
			data-page-size={siteConfig.animeSource?.pageSize || 0}
		>
			<FilterModule
				filters={animeFilters}
				searchPlaceholder={i18n(I18nKey.searchAnime)}
				searchId="anime-search"
				cardSelector=".anime-card"
				searchableFields={[".anime-title", ".anime-description"]}
				filterAttribute="data-status"
				customLogic={true}
			/>

			<div id="anime-list-container" class="anime-list-container">
				{
					allAnime.length === 0 ? (
						<div class="anime-empty">
							<mdui-icon
								name="sentiment_dissatisfied"
								class="anime-empty-icon"
							/>
							<h3>{i18n(I18nKey.animeEmpty)}</h3>
						</div>
					) : (
						allAnime.map((anime) => {
							const getStatus = (anime: any) => {
								if (anime.watchStatus) {
									return anime.watchStatus;
								}
								if (
									anime.progress > 0 &&
									anime.progress < anime.totalEpisodes
								) {
									return "watching";
								}
								if (
									anime.progress >= anime.totalEpisodes &&
									anime.totalEpisodes > 0
								) {
									return "completed";
								}
								return "planned";
							};

							return (
								<AnimeCard
									title={anime.title}
									cover={anime.cover}
									link={anime.link}
									description={anime.description}
									year={anime.year}
									studio={anime.studio}
									progress={anime.progress}
									totalEpisodes={anime.totalEpisodes}
									status={getStatus(anime)}
								/>
							);
						})
					)
				}
			</div>

			{
				siteConfig.animeSource?.pageSize &&
					allAnime.length > siteConfig.animeSource.pageSize && (
						<Pagination
							id="anime-pagination"
							pageSize={siteConfig.animeSource?.pageSize}
							totalItems={allAnime.length}
							itemSelector=".anime-card"
							hiddenClass="flip-hidden"
							customLogic={true}
						/>
					)
			}
			<FlipAnimationModule
				cardSelector=".anime-card"
				listContainerId="anime-list-container"
				paginationId="anime-pagination"
				hiddenClass="flip-hidden"
				pageSize={siteConfig.animeSource?.pageSize || 0}
			/>
		</main>
	</div>

	<Sidebar slot="sidebar" />
</Layout>

<style>
	.anime-container-layout {
		display: flex;
		flex-direction: column;
	}

	.anime-page {
		margin-top: 20px;
		padding: 0;
		flex: 1;
	}

	.anime-list-container {
		display: grid;
		grid-template-columns: 1fr;
		gap: 20px;
		align-content: start;
		align-items: start;
	}

	@media (min-width: 1024px) {
		.anime-list-container {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	.anime-empty {
		text-align: center;
		padding: 60px 20px;
	}

	.anime-empty-icon {
		font-size: 64px;
		color: var(--mdui-color-on-surface-variant, #bdbdbd);
		margin-bottom: 16px;
	}

	.anime-empty h3 {
		font-size: 18px;
		font-weight: 500;
		color: var(--mdui-color-on-surface-variant, #9e9e9e);
		margin: 0;
	}

	:global(.mdui-theme-layout-dark) .filter-buttons button {
		color: rgba(255, 255, 255, 0.9);
		border-color: rgba(255, 255, 255, 0.3);
	}

	:global(.mdui-theme-layout-dark) .search-input {
		background: var(--archive-card-bg);
		color: rgba(255, 255, 255, 0.9);
		border-color: rgba(255, 255, 255, 0.3);
	}

	:global(.mdui-theme-layout-dark) .search-input::placeholder {
		color: rgba(255, 255, 255, 0.5);
	}

	:global(.mdui-theme-layout-dark) .filter-toggle {
		background: var(--archive-card-bg);
		color: rgba(255, 255, 255, 0.9);
		border-color: rgba(255, 255, 255, 0.3);
	}

	:global(.mdui-theme-layout-dark) .filter-popup {
		background: var(--archive-card-bg);
	}

	:global(.mdui-theme-layout-dark) .filter-option {
		color: rgba(255, 255, 255, 0.9);
	}

	:global(.mdui-theme-layout-dark) .filter-option:hover {
		background: rgba(255, 255, 255, 0.1);
	}

	@media (max-width: 900px) {
		.filter-buttons {
			display: none;
		}

		.filter-toggle-wrapper {
			display: block;
		}

		.search-wrapper {
			flex: 1;
			min-width: 0;
		}

		.search-input {
			width: 100%;
		}
	}

	@media (max-width: 600px) {
		.search-wrapper {
			width: 100%;
		}

		.search-input {
			flex: 1;
			min-width: 0;
		}

		.anime-filter {
			flex-direction: column-reverse;
			align-items: stretch;
		}
	}
</style>
